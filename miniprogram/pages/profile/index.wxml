<view class="page-profile">
  <view class="user-block">
    <button class="user-avatar" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
      <image
        wx:if="{{userInfo.avatar_url}}"
        class="avatar-img"
        src="{{userInfo.avatar_url}}"
        mode="aspectFill"
      />
      <view wx:else class="avatar-fallback">
        <text>{{userInfo.nickname ? userInfo.nickname[0] : '用'}}</text>
      </view>
    </button>
    <view class="user-info">
      <input
        class="user-name"
        type="nickname"
        placeholder="点击设置昵称"
        value="{{userInfo.nickname || ''}}"
        bindblur="onNicknameInput"
      />
      <text class="user-sub">微信用户</text>
    </view>
  </view>

  <view class="section" wx:if="{{isArtist}}">
    <text class="section-title">化妆师管理</text>
    <view class="group">
      <view class="menu-item tappable" bindtap="goToAdminWorks">
        <view class="menu-left">
          <text class="menu-text">作品管理</text>
          <text class="menu-note">上传/编辑作品</text>
        </view>
        <view class="menu-arrow"></view>
      </view>
      <view class="menu-item tappable" bindtap="goToAdminServices">
        <view class="menu-left">
          <text class="menu-text">服务管理</text>
          <text class="menu-note">管理服务项目</text>
        </view>
        <view class="menu-arrow"></view>
      </view>
      <view class="menu-item tappable" bindtap="goToAdminBookings">
        <view class="menu-left">
          <text class="menu-text">预约管理</text>
          <text class="menu-note">处理预约请求</text>
        </view>
        <view class="menu-arrow"></view>
      </view>
      <view class="menu-item menu-item--last tappable" bindtap="goToAdminProfile">
        <view class="menu-left">
          <text class="menu-text">个人资料</text>
          <text class="menu-note">编辑个人简介</text>
        </view>
        <view class="menu-arrow"></view>
      </view>
    </view>
  </view>

  <view class="section">
    <text class="section-title">我的</text>
    <view class="group">
      <view class="menu-item menu-item--last tappable" bindtap="goToBookingHistory">
        <view class="menu-left">
          <text class="menu-text">预约记录</text>
          <text class="menu-note">查看预约历史</text>
        </view>
        <view class="menu-arrow"></view>
      </view>
    </view>
  </view>
</view>
