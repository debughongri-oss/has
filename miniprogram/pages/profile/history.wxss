.page-history {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx var(--page-pad);
}

.card {
  background-color: var(--bg-elevated);
  border-radius: 24rpx;
  padding: 22rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

/* ===== 主行 ===== */
.crow {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.cdate {
  width: 124rpx;
  flex-shrink: 0;
  background-color: var(--accent-soft);
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
}

.cdate-d {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--accent);
  line-height: 1.1;
}

.cdate-t {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--accent);
  margin-top: 6rpx;
}

.cmain {
  flex: 1;
  min-width: 0;
}

.ctop {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.csvc {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.badge {
  flex-shrink: 0;
  font-size: 20rpx;
  font-weight: 600;
  padding: 5rpx 18rpx;
  border-radius: 999rpx;
}

.badge--pending {
  background-color: var(--orange-bg);
  color: var(--orange);
}

.badge--accepted {
  background-color: var(--green-bg);
  color: var(--green);
}

.badge--completed {
  background-color: var(--purple-bg);
  color: var(--purple);
}

.badge--cancelled,
.badge--rejected {
  background-color: var(--fill-primary);
  color: var(--text-secondary);
}

.cfulldate {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

/* ===== 拒绝原因 / 备注 ===== */
.creason {
  font-size: 22rpx;
  color: var(--red);
  background-color: var(--red-bg);
  border-radius: 14rpx;
  padding: 14rpx 20rpx;
  margin-top: 18rpx;
  line-height: 1.5;
}

.cnote {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 18rpx;
  line-height: 1.6;
}

/* ===== 操作 ===== */
.cact {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 14rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--separator);
}

.act-cancel {
  padding: 12rpx 30rpx;
  border-radius: 999rpx;
  background-color: var(--fill-primary);
  color: var(--red);
  font-size: 24rpx;
  font-weight: 600;
}

.act-review {
  padding: 12rpx 34rpx;
  border-radius: 999rpx;
  background-color: var(--accent);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(255, 111, 139, 0.32);
}

.act-reviewed {
  display: flex;
  align-items: center;
  gap: 6rpx;
  color: var(--text-tertiary);
  font-size: 24rpx;
}

.act-reviewed .star {
  color: #B0883F;
}
