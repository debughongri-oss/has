<view class="page-history">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <view class="list" wx:if="{{!loading && bookings.length}}">
    <view class="card" wx:for="{{bookings}}" wx:key="_id">
      <view class="crow">
        <view class="cdate">
          <text class="cdate-d">{{item.dateShort}}</text>
          <text class="cdate-t">{{item.booking_time}}</text>
        </view>
        <view class="cmain">
          <view class="ctop">
            <text class="csvc text-ellipsis">{{item.service_name}}</text>
            <text class="badge badge--{{item.status}}">{{item.statusLabel}}</text>
          </view>
          <text class="cfulldate">{{item.dateLabel}}</text>
        </view>
      </view>

      <view class="creason" wx:if="{{item.reject_reason}}">拒绝原因：{{item.reject_reason}}</view>
      <text class="cnote" wx:if="{{item.notes}}">{{item.notes}}</text>

      <view class="cact" wx:if="{{item.status === 'pending' || item.status === 'completed'}}">
        <view class="act-cancel" wx:if="{{item.status === 'pending'}}" bindtap="cancelBooking" data-id="{{item._id}}">取消预约</view>
        <view class="act-review" wx:if="{{item.status === 'completed' && !reviewMap[item._id]}}" bindtap="goToReview" data-id="{{item._id}}">去评价</view>
        <view class="act-reviewed" wx:if="{{item.status === 'completed' && reviewMap[item._id]}}">
          <text class="star">★</text>已评价
        </view>
      </view>
    </view>
  </view>

  <view class="empty-container" wx:if="{{!loading && !bookings.length}}">
    <view class="empty">
      <view class="empty-icon"></view>
      <text class="empty-text">暂无预约记录</text>
    </view>
  </view>
</view>
