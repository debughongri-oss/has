<view class="admin-works">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading}}">
    <view class="whead">
      <text class="wcount">共 <text class="wcount-n">{{works.length}}</text> 件作品</text>
      <view class="wadd tappable" bindtap="goToAdd">
        <text class="plus">+</text>
        <text>添加作品</text>
      </view>
    </view>

    <view class="list" wx:if="{{works.length}}">
      <view class="wcard" wx:for="{{works}}" wx:key="_id">
        <view class="wthumb">
          <image class="wthumb-img" src="{{item.images[0]}}" mode="aspectFill" lazy-load />
        </view>
        <view class="wbody">
          <view class="wtop">
            <text class="wtitle text-ellipsis">{{item.title}}</text>
            <text class="wbadge" wx:if="{{item.is_featured}}">精选</text>
          </view>
          <text class="wmeta">{{item.categoryLabel}} · {{item.imageCount}} 张图</text>
          <view class="wacts">
            <view class="wedit tappable" bindtap="goToEdit" data-id="{{item._id}}">编辑</view>
            <view class="wdel tappable" bindtap="confirmDelete" data-id="{{item._id}}" data-index="{{index}}">删除</view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-container" wx:if="{{!works.length}}">
      <view class="empty">
        <view class="empty-icon"></view>
        <text class="empty-text">还没有作品，点击右上角添加</text>
      </view>
    </view>
  </block>

  <t-dialog
    visible="{{showDeleteDialog}}"
    title="确认删除"
    content="删除后无法恢复，确定要删除这个作品吗？"
    confirm-btn="删除"
    cancel-btn="取消"
    bind:confirm="onDeleteConfirm"
    bind:cancel="onDeleteCancel"
  />
</view>
