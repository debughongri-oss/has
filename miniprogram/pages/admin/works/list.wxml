<view class="admin-works">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading}}">
    <view class="top-bar">
      <view class="add-btn tappable" bindtap="goToAdd">添加作品</view>
    </view>

    <view class="list" wx:if="{{works.length}}">
      <view class="item tappable" wx:for="{{works}}" wx:key="_id">
        <image class="item-img" src="{{item.images[0]}}" mode="aspectFill" lazy-load />
        <view class="item-body">
          <text class="item-title text-ellipsis">{{item.title}}</text>
          <text class="item-meta">{{item.category}} · {{item.images.length}}张</text>
        </view>
        <view class="item-btns">
          <text class="item-edit tappable" bindtap="goToEdit" data-id="{{item._id}}">编辑</text>
          <text class="item-del tappable" bindtap="confirmDelete" data-id="{{item._id}}" data-index="{{index}}">删除</text>
        </view>
      </view>
    </view>

    <view class="empty-container" wx:if="{{!works.length}}">
      <t-empty icon="image" description="还没有作品" />
    </view>
  </block>

  <t-dialog
    visible="{{showDeleteDialog}}"
    title="确认删除"
    content="删除后无法恢复，确定要删除这个作品吗？"
    confirm-btn="删除"
    cancel-btn="取消"
    bind:confirm="onDeleteConfirm"
    bind:cancel="onDeleteCancel"
  />
</view>
