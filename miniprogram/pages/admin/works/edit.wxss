.edit-work {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* ===== 卡片 ===== */
.card {
  margin: 24rpx var(--page-pad) 0;
  background-color: var(--bg-elevated);
  border-radius: 26rpx;
  padding: 26rpx 28rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.card-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.card-meta {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* ===== 标题输入 ===== */
.field {
  display: flex;
  align-items: center;
  min-height: 88rpx;
}

.field-key {
  width: 120rpx;
  font-size: 30rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.field-val {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  padding: 0;
}

.ph {
  color: var(--text-tertiary);
}

.divline {
  height: 1rpx;
  background-color: var(--separator);
  margin: 6rpx 0 22rpx;
}

/* ===== 分类 chips ===== */
.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background-color: var(--fill-primary);
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.chip--on {
  background-color: var(--accent-soft);
  color: var(--accent);
  border-color: var(--accent);
  font-weight: 600;
}

/* ===== 图片网格 ===== */
.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.cell {
  position: relative;
  height: 196rpx;
  border-radius: 18rpx;
  overflow: hidden;
}

.cell-img {
  width: 100%;
  height: 100%;
}

.cell-del {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5) var(--icon-close) no-repeat center / 22rpx;
}

.add {
  height: 196rpx;
  border: 2rpx dashed var(--separator-opaque);
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: var(--text-tertiary);
}

.add-plus {
  font-size: 56rpx;
  font-weight: 200;
  line-height: 1;
}

.add-t {
  font-size: 22rpx;
}

/* ===== 妆前对比照 ===== */
.hint {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
  margin-bottom: 18rpx;
}

.before-empty {
  height: 240rpx;
  border: 2rpx dashed var(--separator-opaque);
  border-radius: 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  color: var(--text-tertiary);
}

.before-plus {
  font-size: 56rpx;
  font-weight: 200;
  line-height: 1;
}

.before-t {
  font-size: 24rpx;
}

.before-card {
  position: relative;
  height: 240rpx;
  border-radius: 18rpx;
  overflow: hidden;
}

.before-img {
  width: 100%;
  height: 100%;
}

.before-del {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5) var(--icon-close) no-repeat center / 24rpx;
}

/* ===== 描述 ===== */
.ta {
  width: 100%;
  min-height: 180rpx;
  font-size: var(--fs-sm);
  line-height: 1.7;
  color: var(--text-primary);
  padding: 0;
}

/* ===== 展示设置 ===== */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.switch-main {
  flex: 1;
  min-width: 0;
}

.switch-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.switch-note {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

/* ===== 保存栏 ===== */
.save-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--bg-elevated);
  box-shadow: 0 -8rpx 26rpx rgba(0, 0, 0, 0.07);
  padding: 18rpx var(--page-pad);
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
}

.save-btn {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--accent-dark);
  color: #FFFFFF;
  border-radius: 24rpx;
  font-size: var(--fs-base);
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
  box-shadow: 0 10rpx 24rpx rgba(232, 85, 117, 0.34);
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  opacity: 0.9;
  transform: scale(0.99);
}

.save-btn[disabled] {
  opacity: 0.45;
}
