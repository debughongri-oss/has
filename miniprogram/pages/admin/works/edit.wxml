<view class="edit-work">
  <!-- 作品信息 -->
  <view class="card">
    <view class="card-head"><text class="card-title">作品信息</text></view>
    <view class="field">
      <text class="field-key">标题</text>
      <input class="field-val" placeholder="输入作品标题" placeholder-class="ph" value="{{title}}" bindinput="onTitleInput" />
    </view>
    <view class="divline"></view>
    <view class="chips">
      <view
        class="chip {{category === item.key ? 'chip--on' : ''}} tappable"
        wx:for="{{categories}}"
        wx:key="key"
        bindtap="onCategoryPick"
        data-key="{{item.key}}"
      >{{item.label}}</view>
    </view>
  </view>

  <!-- 作品图片 -->
  <view class="card">
    <view class="card-head">
      <text class="card-title">作品图片</text>
      <text class="card-meta">{{images.length}} / 9</text>
    </view>
    <view class="grid">
      <view class="cell" wx:for="{{images}}" wx:key="index">
        <image class="cell-img" src="{{item}}" mode="aspectFill" />
        <view class="cell-del tappable" bindtap="removeImage" data-index="{{index}}"></view>
      </view>
      <view class="add tappable" wx:if="{{images.length < 9}}" bindtap="chooseImages">
        <text class="add-plus">+</text>
        <text class="add-t">添加</text>
      </view>
    </view>
  </view>

  <!-- 妆前对比照 -->
  <view class="card">
    <view class="card-head">
      <text class="card-title">妆前对比照</text>
      <text class="card-meta">选填</text>
    </view>
    <text class="hint">上传妆前照片，作品详情页会展示「妆前 / 妆后」对比滑块</text>
    <view class="before-empty tappable" wx:if="{{!beforeImage}}" bindtap="chooseBeforeImage">
      <text class="before-plus">+</text>
      <text class="before-t">上传妆前照片</text>
    </view>
    <view class="before-card" wx:else>
      <image class="before-img" src="{{beforeImage}}" mode="aspectFill" />
      <view class="before-del tappable" bindtap="removeBeforeImage"></view>
    </view>
  </view>

  <!-- 作品描述 -->
  <view class="card">
    <view class="card-head">
      <text class="card-title">作品描述</text>
      <text class="card-meta">{{description.length}} / 500</text>
    </view>
    <textarea class="ta" placeholder="描述一下这个作品..." placeholder-class="ph" value="{{description}}" bindinput="onDescInput" maxlength="500" />
  </view>

  <!-- 展示设置 -->
  <view class="card">
    <view class="card-head"><text class="card-title">展示设置</text></view>
    <view class="switch-row">
      <view class="switch-main">
        <text class="switch-title">设为精选</text>
        <text class="switch-note">精选作品会展示在首页的精选作品区</text>
      </view>
      <switch checked="{{isFeatured}}" bindchange="onFeaturedChange" color="#FF6F8B" />
    </view>
  </view>

  <view class="save-bar">
    <button class="save-btn" bindtap="saveWork" disabled="{{saving}}">{{saving ? '保存中...' : '保存作品'}}</button>
  </view>
</view>
