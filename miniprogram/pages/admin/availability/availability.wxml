<view class="availability-page">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading}}">
    <view class="hero-card">
      <view class="hero-head">
        <view>
          <text class="hero-kicker">{{monthLabel}}</text>
          <text class="hero-title">不可约时间</text>
        </view>
        <button class="add-btn {{showAdd ? 'add-btn--open' : ''}}" bindtap="onToggleAdd">
          <text class="add-ic"></text>
          <text>{{showAdd ? '收起' : '添加'}}</text>
        </button>
      </view>
      <view class="summary-row">
        <view class="summary-item">
          <text class="summary-num">{{blocks.length}}</text>
          <text class="summary-label">屏蔽记录</text>
        </view>
        <view class="summary-item">
          <text class="summary-num">{{allDayCount}}</text>
          <text class="summary-label">全天</text>
        </view>
        <view class="summary-item">
          <text class="summary-num">{{slotCount}}</text>
          <text class="summary-label">时段</text>
        </view>
      </view>
    </view>

    <!-- 添加表单 -->
    <view class="add-form" wx:if="{{showAdd}}">
      <view class="form-head">
        <text class="form-title">新增屏蔽</text>
        <text class="form-state">{{newTime ? '指定时段' : '全天不可约'}}</text>
      </view>

      <view class="field">
        <text class="form-label">日期</text>
        <picker class="date-picker" mode="date" value="{{newDate}}" bindchange="onDateChange">
          <view class="picker-value {{newDate ? '' : 'ph'}}">
            <text>{{newDate || '选择日期'}}</text>
            <text class="picker-arrow"></text>
          </view>
        </picker>
      </view>

      <view class="field field--col">
        <text class="form-label">时段</text>
        <view class="time-options">
          <view class="time-chip {{newTime === '' ? 'active' : ''}} tappable" bindtap="onTimePick" data-time="">全天</view>
          <view class="time-chip {{newTime === item ? 'active' : ''}} tappable" wx:for="{{timeSlots}}" wx:key="*this" bindtap="onTimePick" data-time="{{item}}">{{item}}</view>
        </view>
      </view>

      <view class="field">
        <text class="form-label">备注</text>
        <input class="form-input" placeholder="个人事务/假期" placeholder-class="ph" value="{{newReason}}" bindinput="onReasonInput" />
      </view>

      <button class="form-submit" bindtap="onAddBlock">确认屏蔽</button>
    </view>

    <!-- 屏蔽列表 -->
    <view class="section" wx:if="{{blocks.length}}">
      <view class="section-head">
        <text class="section-title">已屏蔽时间</text>
        <text class="section-count">{{blocks.length}} 条</text>
      </view>
      <view class="block-list">
        <view class="block-card {{item.isAllDay ? 'block-card--all' : ''}}" wx:for="{{blocks}}" wx:key="_id">
          <view class="date-badge">
            <text class="date-day">{{item.dayLabel}}</text>
            <text class="date-week">{{item.weekdayLabel}}</text>
          </view>
          <view class="block-info">
            <view class="block-top">
              <text class="block-time">{{item.timeLabel}}</text>
              <text class="block-kind">{{item.isAllDay ? '全天' : '时段'}}</text>
            </view>
            <text class="block-date">{{item.dateLabel}}</text>
            <text class="block-reason text-ellipsis">{{item.reasonLabel}}</text>
          </view>
          <view class="block-remove tappable" bindtap="onRemoveBlock" data-id="{{item._id}}">取消</view>
        </view>
      </view>
    </view>

    <view class="empty" wx:if="{{!blocks.length}}">
      <view class="empty-icon"></view>
      <text class="empty-text">暂无屏蔽时间</text>
    </view>
  </block>
</view>
