<view class="dashboard">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading && stats}}">
    <view class="overview">
      <view class="overview-head">
        <view>
          <text class="overview-kicker">{{stats.monthLabel}}</text>
          <text class="overview-title">经营概览</text>
        </view>
        <view class="health {{stats.thisMonth.pending ? 'health--alert' : ''}}">
          <text class="health-dot"></text>
          <text>{{stats.statusSummary}}</text>
        </view>
      </view>
      <view class="overview-main">
        <text class="overview-num">{{stats.thisMonth.total}}</text>
        <text class="overview-unit">单预约</text>
      </view>
      <view class="overview-foot">
        <text class="mom {{stats.momUp ? 'mom--up' : 'mom--down'}}">较上月 {{stats.momText}}</text>
        <text>上月 {{stats.lastMonthTotal}} 单</text>
      </view>
    </view>

    <!-- 核心指标 -->
    <view class="metric-grid">
      <view class="metric-card">
        <view class="metric-top">
          <view class="metric-icon metric-icon--money"></view>
          <text class="metric-label">预估营收</text>
        </view>
        <view class="metric-value metric-value--money"><text class="metric-prefix">¥</text>{{stats.revenueText}}</view>
        <text class="metric-note">已完成预约</text>
      </view>
      <view class="metric-card">
        <view class="metric-top">
          <view class="metric-icon metric-icon--rate"></view>
          <text class="metric-label">完成率</text>
        </view>
        <view class="metric-value">{{stats.completedRate}}<text class="metric-suffix">%</text></view>
        <text class="metric-note">{{stats.thisMonth.completed}} 单完成</text>
      </view>
      <view class="metric-card">
        <view class="metric-top">
          <view class="metric-icon metric-icon--review"></view>
          <text class="metric-label">平均评分</text>
        </view>
        <view class="metric-value">{{stats.reviewStats.average}}<text class="metric-suffix">分</text></view>
        <text class="metric-note">{{stats.reviewStats.total}} 条评价</text>
      </view>
      <view class="metric-card">
        <view class="metric-top">
          <view class="metric-icon metric-icon--pending"></view>
          <text class="metric-label">待确认</text>
        </view>
        <view class="metric-value">{{stats.thisMonth.pending}}<text class="metric-suffix">单</text></view>
        <text class="metric-note">需要跟进</text>
      </view>
    </view>

    <!-- 预约状态分布 -->
    <view class="section">
      <view class="section-head">
        <text class="section-title">预约状态分布</text>
        <text class="section-note">共 {{stats.thisMonth.total}} 单</text>
      </view>
      <view class="status-list">
        <view class="status-row" wx:for="{{stats.statusBreakdown}}" wx:key="key">
          <view class="status-meta">
            <view class="status-name-wrap">
              <text class="status-dot status-dot--{{item.key}}"></text>
              <text class="status-name">{{item.name}}</text>
            </view>
            <text class="status-count">{{item.count}} 单 · {{item.percent}}%</text>
          </view>
          <view class="status-track">
            <view class="status-fill status-fill--{{item.key}}" style="width:{{item.percent}}%;"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- 热门服务 -->
    <view class="section">
      <view class="section-head">
        <text class="section-title">热门服务</text>
        <text class="section-note" wx:if="{{stats.topServices.length}}">Top{{stats.topServices.length}}</text>
      </view>
      <view class="rank-list" wx:if="{{stats.topServices.length}}">
        <view class="rank-row" wx:for="{{stats.topServices}}" wx:key="name">
          <text class="rank-num">{{index + 1}}</text>
          <view class="rank-main">
            <view class="rank-top">
              <text class="rank-name text-ellipsis">{{item.name}}</text>
              <text class="rank-count">{{item.count}} 单</text>
            </view>
            <view class="rank-track">
              <view class="rank-fill" style="width:{{item.percent}}%;"></view>
            </view>
          </view>
        </view>
      </view>
      <view class="mini-empty" wx:else>
        <text class="mini-empty-title">暂无热门服务</text>
        <text class="mini-empty-sub">本月有预约后将自动生成排行</text>
      </view>
    </view>
  </block>

  <view class="empty-container" wx:if="{{!loading && !stats}}">
    <view class="empty">
      <view class="empty-icon"></view>
      <text class="empty-text">经营数据加载失败</text>
      <view class="retry-btn tappable" bindtap="loadStats">重新加载</view>
    </view>
  </view>
</view>
