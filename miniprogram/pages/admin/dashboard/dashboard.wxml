<view class="dashboard">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading && stats}}">
    <!-- 核心指标 -->
    <view class="stat-grid">
      <view class="stat-card">
        <text class="stat-num">{{stats.thisMonth.total}}</text>
        <text class="stat-label">本月预约</text>
        <text class="stat-mom {{stats.momUp ? 'mom-up' : 'mom-down'}}">{{stats.momText}}</text>
      </view>
      <view class="stat-card">
        <text class="stat-num">{{stats.reviewStats.average}}</text>
        <text class="stat-label">平均评分</text>
        <text class="stat-sub">{{stats.reviewStats.total}} 条评价</text>
      </view>
    </view>

    <!-- 预约状态分布 -->
    <view class="section">
      <text class="section-title">预约状态分布</text>
      <view class="status-list">
        <view class="status-row">
          <text class="status-dot" style="background:var(--orange)"></text>
          <text class="status-name">待确认</text>
          <text class="status-count">{{stats.thisMonth.pending}}</text>
        </view>
        <view class="status-row">
          <text class="status-dot" style="background:var(--green)"></text>
          <text class="status-name">已确认</text>
          <text class="status-count">{{stats.thisMonth.accepted}}</text>
        </view>
        <view class="status-row">
          <text class="status-dot" style="background:var(--text-tertiary)"></text>
          <text class="status-name">已完成</text>
          <text class="status-count">{{stats.thisMonth.completed}}</text>
        </view>
        <view class="status-row">
          <text class="status-dot" style="background:var(--red)"></text>
          <text class="status-name">已拒绝</text>
          <text class="status-count">{{stats.thisMonth.rejected}}</text>
        </view>
        <view class="status-row">
          <text class="status-dot" style="background:var(--text-tertiary)"></text>
          <text class="status-name">已取消</text>
          <text class="status-count">{{stats.thisMonth.cancelled}}</text>
        </view>
      </view>
    </view>

    <!-- 热门服务 -->
    <view class="section" wx:if="{{stats.topServices.length}}">
      <text class="section-title">热门服务 Top{{stats.topServices.length}}</text>
      <view class="rank-list">
        <view class="rank-row" wx:for="{{stats.topServices}}" wx:key="name">
          <text class="rank-num">{{index + 1}}</text>
          <text class="rank-name">{{item.name}}</text>
          <text class="rank-count">{{item.count}} 单</text>
        </view>
      </view>
    </view>
  </block>
</view>
