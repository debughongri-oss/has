.dashboard {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 核心指标卡片 */
.stat-grid {
  display: flex;
  gap: 16rpx;
  padding: 24rpx var(--page-pad);
}

.stat-card {
  flex: 1;
  background-color: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.stat-num {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.1;
}

.stat-label {
  font-size: var(--fs-xs);
  color: var(--text-secondary);
}

.stat-mom {
  font-size: 20rpx;
  margin-top: 4rpx;
}

.mom-up { color: var(--green); }
.mom-down { color: var(--red); }

.stat-sub {
  font-size: 20rpx;
  color: var(--text-tertiary);
}

/* 通用 section */
.section {
  margin: 8rpx var(--page-pad) 0;
  background-color: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: 26rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: var(--fs-sm);
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  display: block;
}

/* 状态分布 */
.status-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.status-name {
  flex: 1;
  font-size: var(--fs-xs);
  color: var(--text-secondary);
}

.status-count {
  font-size: var(--fs-sm);
  font-weight: 700;
  color: var(--text-primary);
}

/* 排行榜 */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.rank-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rank-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: var(--accent-soft);
  color: var(--accent);
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rank-name {
  flex: 1;
  font-size: var(--fs-xs);
  color: var(--text-primary);
}

.rank-count {
  font-size: var(--fs-xs);
  font-weight: 600;
  color: var(--text-secondary);
}
