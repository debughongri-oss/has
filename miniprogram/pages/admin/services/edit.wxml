<view class="edit-service">
  <!-- 基本信息 -->
  <view class="card">
    <view class="card-head"><text class="card-title">基本信息</text></view>
    <view class="field">
      <text class="field-key">名称</text>
      <input class="field-val" placeholder="如：韩式新娘妆" placeholder-class="ph" value="{{name}}" bindinput="onNameInput" />
    </view>
    <view class="divline"></view>
    <view class="duo">
      <view class="box">
        <text class="box-label">价格</text>
        <view class="box-row">
          <text class="box-affix">¥</text>
          <input class="box-input" placeholder="面议" placeholder-class="box-ph" value="{{price}}" bindinput="onPriceInput" />
        </view>
      </view>
      <view class="box">
        <text class="box-label">时长</text>
        <view class="box-row">
          <input class="box-input" type="number" placeholder="0" placeholder-class="box-ph" value="{{duration}}" bindinput="onDurationInput" />
          <text class="box-affix">分钟</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 服务分类 -->
  <view class="card">
    <view class="card-head"><text class="card-title">服务分类</text></view>
    <view class="chips">
      <view
        class="chip {{category === item.key ? 'chip--on' : ''}} tappable"
        wx:for="{{categories}}"
        wx:key="key"
        bindtap="onCategoryPick"
        data-key="{{item.key}}"
      >{{item.label}}</view>
    </view>
  </view>

  <!-- 服务描述 -->
  <view class="card">
    <view class="card-head">
      <text class="card-title">服务描述</text>
      <text class="card-meta">{{description.length}} / 500</text>
    </view>
    <textarea
      class="ta"
      placeholder="描述服务内容、包含的项目、适合的场景等..."
      placeholder-class="ph"
      value="{{description}}"
      bindinput="onDescInput"
      maxlength="500"
    />
  </view>

  <!-- 预约设置 -->
  <view class="card">
    <view class="card-head"><text class="card-title">预约设置</text></view>
    <view class="field">
      <text class="field-key">可预约窗口</text>
      <input class="field-val" type="number" placeholder="不限" placeholder-class="ph" value="{{bookingWindow}}" bindinput="onWindowInput" />
    </view>
    <text class="hint">客户最多可提前多少天预约（单位：天）；留空 = 不限，可选任意未来日期</text>
  </view>

  <!-- 显示设置 -->
  <view class="card">
    <view class="card-head"><text class="card-title">显示设置</text></view>
    <view class="field">
      <text class="field-key">排序</text>
      <input class="field-val" type="number" placeholder="0" placeholder-class="ph" value="{{sortOrder}}" bindinput="onSortInput" />
    </view>
    <text class="hint">数字越小越靠前，默认为 0</text>
  </view>

  <view class="save-bar">
    <button class="save-btn" bindtap="saveService" disabled="{{saving}}">{{saving ? '保存中...' : '保存服务'}}</button>
  </view>
</view>
