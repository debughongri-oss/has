<view class="admin-services">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading}}">
    <view class="whead">
      <text class="wcount">共 <text class="wcount-n">{{services.length}}</text> 项服务</text>
      <view class="wadd tappable" bindtap="goToAdd">
        <text class="plus">+</text>
        <text>添加服务</text>
      </view>
    </view>

    <view class="list" wx:if="{{services.length}}">
      <view
        class="scard {{item.is_active === false ? 'scard--off' : ''}}"
        wx:for="{{services}}"
        wx:key="_id"
      >
        <view class="stop">
          <view class="sic sic--{{item.tone}}">{{item.icon}}</view>
          <view class="smain">
            <view class="snamerow">
              <text class="sname text-ellipsis">{{item.name}}</text>
              <text class="sbadge" wx:if="{{item.is_active === false}}">已隐藏</text>
            </view>
            <text class="sdesc text-ellipsis-2" wx:if="{{item.description}}">{{item.description}}</text>
          </view>
        </view>
        <view class="sfoot">
          <view class="sleft">
            <view class="sprice" wx:if="{{item.price}}">
              <text class="sprice-sym">¥</text>
              <text class="sprice-num">{{item.price}}</text>
            </view>
            <text class="sdur" wx:if="{{item.duration}}">{{item.duration}}分钟</text>
          </view>
          <view class="sacts">
            <view class="sedit tappable" bindtap="goToEdit" data-id="{{item._id}}">编辑</view>
            <view class="sdel tappable" bindtap="confirmDelete" data-id="{{item._id}}" data-index="{{index}}">删除</view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{!services.length}}">
      <text class="empty-title">还没有服务项目</text>
      <text class="empty-sub">添加你的第一项妆容服务</text>
      <view class="empty-cta tappable" bindtap="goToAdd">
        <text class="empty-cta-text">立即添加</text>
      </view>
    </view>
  </block>

  <t-dialog
    visible="{{showDeleteDialog}}"
    title="确认删除"
    content="删除后无法恢复，确定要删除这个服务吗？"
    confirm-btn="删除"
    cancel-btn="取消"
    bind:confirm="onDeleteConfirm"
    bind:cancel="onDeleteCancel"
  />
</view>
