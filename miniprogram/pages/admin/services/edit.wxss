.edit-service {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* ===== 卡片 ===== */
.card {
  margin: 24rpx var(--page-pad) 0;
  background-color: var(--bg-elevated);
  border-radius: 26rpx;
  padding: 26rpx 28rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.card-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.card-meta {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* ===== 封面 ===== */
.cover {
  display: flex;
}

.cover-preview {
  position: relative;
  width: 100%;
  height: 320rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.cover-img {
  width: 100%;
  height: 100%;
  display: block;
}

.cover-del {
  position: absolute;
  top: 14rpx;
  right: 14rpx;
  width: 48rpx;
  height: 48rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.5);
  color: #FFFFFF;
  font-size: 36rpx;
}

.cover-add {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 320rpx;
  border: 2rpx dashed var(--separator);
  border-radius: 20rpx;
  background-color: var(--fill-primary);
}

.cover-add-plus {
  font-size: 56rpx;
  font-weight: 300;
  line-height: 1;
  color: var(--text-tertiary);
}

.cover-add-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* ===== 名称 / 排序 行 ===== */
.field {
  display: flex;
  align-items: center;
  min-height: 88rpx;
}

.field-key {
  width: 120rpx;
  font-size: 30rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.field-val {
  flex: 1;
  height: 88rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  padding: 0;
}

.ph {
  color: var(--text-tertiary);
}

.divline {
  height: 1rpx;
  background-color: var(--separator);
  margin: 6rpx 0 22rpx;
}

/* ===== 价格 / 时长 双列 ===== */
.duo {
  display: flex;
  gap: 16rpx;
}

.box {
  flex: 1;
  min-width: 0;
  background-color: var(--fill-primary);
  border-radius: 18rpx;
  padding: 20rpx 22rpx;
}

.box-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.box-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.box-affix {
  font-size: 26rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
}

.box-input {
  flex: 1;
  min-width: 0;
  height: 52rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
  padding: 0;
}

.box-ph {
  color: var(--text-tertiary);
  font-weight: 400;
}

/* ===== 分类 chips ===== */
.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background-color: var(--fill-primary);
  color: var(--text-secondary);
  border: 2rpx solid transparent;
}

.chip--on {
  background-color: var(--accent-soft);
  color: var(--accent);
  border-color: var(--accent);
  font-weight: 600;
}

/* ===== 描述 ===== */
.ta {
  width: 100%;
  min-height: 180rpx;
  font-size: var(--fs-sm);
  line-height: 1.7;
  color: var(--text-primary);
  padding: 0;
}

/* ===== 显示设置 ===== */
.hint {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  line-height: 1.5;
  margin-top: 6rpx;
}

/* ===== 保存栏 ===== */
.save-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--bg-elevated);
  box-shadow: 0 -8rpx 26rpx rgba(0, 0, 0, 0.07);
  padding: 18rpx var(--page-pad);
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
}

.save-btn {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--accent-dark);
  color: #FFFFFF;
  border-radius: 24rpx;
  font-size: var(--fs-base);
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
  box-shadow: 0 10rpx 24rpx rgba(232, 85, 117, 0.34);
}

.save-btn::after {
  border: none;
}

.save-btn:active {
  opacity: 0.9;
  transform: scale(0.99);
}

.save-btn[disabled] {
  opacity: 0.45;
}
