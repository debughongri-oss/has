.admin-services {
  min-height: 100vh;
  background-color: var(--bg);
}

.top-bar {
  padding: var(--page-pad) var(--page-pad) 0;
}

.add-btn {
  text-align: center;
  padding: 24rpx;
  background-color: var(--accent);
  color: #FDFBF8;
  border-radius: var(--radius-md);
  font-size: var(--fs-sm);
  font-weight: 500;
}

.list {
  padding: 24rpx var(--page-pad);
}

.item {
  display: flex;
  align-items: center;
  background-color: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: var(--page-pad);
  margin-bottom: 12rpx;
}

.item-body {
  flex: 1;
  min-width: 0;
}

.item-name {
  display: block;
  font-size: var(--fs-sm);
  font-weight: 600;
  color: var(--text-primary);
}

.item-meta {
  display: block;
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.item-btns {
  display: flex;
  gap: 16rpx;
  flex-shrink: 0;
}

.item-edit {
  font-size: var(--fs-xs);
  color: var(--accent);
  font-weight: 500;
  text-align: center;
}

.item-del {
  font-size: var(--fs-xs);
  color: var(--red);
  font-weight: 500;
  text-align: center;
}

.empty-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 40vh;
}
