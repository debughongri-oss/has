.admin-services {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ===== 头部 ===== */
.whead {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx var(--page-pad) 20rpx;
}

.wcount {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.wcount-n {
  color: var(--accent);
}

.wadd {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 74rpx;
  padding: 0 34rpx;
  background-color: var(--accent-dark);
  color: #FFFFFF;
  border-radius: 999rpx;
  font-size: var(--fs-sm);
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(232, 85, 117, 0.32);
}

.wadd .plus {
  font-size: 34rpx;
  font-weight: 400;
  line-height: 1;
}

/* ===== 服务卡 ===== */
.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 var(--page-pad);
}

.scard {
  background-color: var(--bg-elevated);
  border-radius: 26rpx;
  padding: 24rpx 26rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.scard--off {
  opacity: 0.72;
}

.stop {
  display: flex;
  gap: 20rpx;
}

.sic {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  flex-shrink: 0;
  overflow: hidden;
}

.sic-cover {
  width: 100%;
  height: 100%;
  display: block;
}

.sic--rose { background-color: rgba(196, 114, 127, 0.13); color: #C4727F; }
.sic--purple { background-color: rgba(139, 111, 160, 0.13); color: #8B6FA0; }
.sic--gold { background-color: rgba(201, 169, 110, 0.16); color: #B0883F; }
.sic--green { background-color: rgba(90, 158, 111, 0.13); color: #5A9E6F; }
.sic--blue { background-color: rgba(90, 127, 160, 0.13); color: #5A7FA0; }

.smain {
  flex: 1;
  min-width: 0;
}

.snamerow {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sname {
  flex: 1;
  min-width: 0;
  font-size: var(--fs-base);
  font-weight: 700;
  color: var(--text-primary);
}

.sbadge {
  flex-shrink: 0;
  font-size: 20rpx;
  color: var(--text-secondary);
  background-color: var(--fill-primary);
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.sdesc {
  display: block;
  margin-top: 8rpx;
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  line-height: 1.6;
}

.sfoot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--separator);
}

.sleft {
  display: flex;
  align-items: baseline;
  min-width: 0;
}

.sprice {
  display: flex;
  align-items: baseline;
  color: var(--accent);
}

.sprice-sym {
  font-size: var(--fs-xs);
  font-weight: 700;
}

.sprice-num {
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
}

.sdur {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
  margin-left: 12rpx;
}

.sacts {
  display: flex;
  gap: 14rpx;
  flex-shrink: 0;
}

.sedit {
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--accent);
  color: var(--accent);
  font-weight: 600;
  font-size: 24rpx;
}

.sdel {
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  background-color: var(--red-bg);
  color: var(--red);
  font-weight: 600;
  font-size: 24rpx;
}

/* ===== 空态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 140rpx var(--page-pad) 0;
  gap: 16rpx;
}

.empty-title {
  font-size: var(--fs-base);
  color: var(--text-primary);
  font-weight: 600;
}

.empty-sub {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
}

.empty-cta {
  margin-top: 20rpx;
  padding: 16rpx 48rpx;
  background-color: var(--accent-soft);
  border-radius: 999rpx;
}

.empty-cta-text {
  font-size: var(--fs-sm);
  color: var(--accent);
  font-weight: 600;
  letter-spacing: 1rpx;
}
