.page {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

/* ===== 卡片 ===== */
.card {
  margin: 24rpx var(--page-pad) 0;
  background-color: var(--bg-elevated);
  border-radius: 26rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-tertiary);
  letter-spacing: 1rpx;
  margin-bottom: 18rpx;
}

/* ===== 概要头部 ===== */
.status-pill {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 700;
  padding: 8rpx 24rpx;
  border-radius: 999rpx;
}

.status-pill--pending {
  background-color: var(--orange-bg);
  color: var(--orange);
}

.status-pill--accepted {
  background-color: var(--green-bg);
  color: var(--green);
}

.status-pill--completed {
  background-color: var(--purple-bg);
  color: var(--purple);
}

.status-pill--cancelled,
.status-pill--rejected {
  background-color: var(--fill-primary);
  color: var(--text-secondary);
}

.h-svc {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-top: 18rpx;
  letter-spacing: -0.5rpx;
}

.h-div {
  height: 1rpx;
  background-color: var(--separator);
  margin: 24rpx 0 4rpx;
}

.h-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.h-key {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.h-val {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.h-val--accent {
  color: var(--accent);
}

/* ===== 详情字段 ===== */
.dfield {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.dfield:last-child {
  border-bottom: none;
}

.dfield-key {
  width: 150rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.dfield-val {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
}

/* ===== 拒绝原因 ===== */
.reason {
  display: block;
  font-size: 28rpx;
  color: var(--red);
  line-height: 1.6;
}

/* ===== 内部备注 ===== */
.ta {
  width: 100%;
  min-height: 150rpx;
  padding: 24rpx;
  background-color: var(--fill-primary);
  border-radius: 18rpx;
  font-size: var(--fs-sm);
  line-height: 1.7;
  color: var(--text-primary);
  box-sizing: border-box;
}

.ta-ph {
  color: var(--text-tertiary);
}

.save-mini {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 64rpx;
  padding: 0 36rpx;
  margin-top: 18rpx;
  background-color: var(--accent-soft);
  color: var(--accent);
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 600;
}

/* ===== 操作栏 ===== */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 16rpx;
  background-color: var(--bg-elevated);
  box-shadow: 0 -8rpx 26rpx rgba(0, 0, 0, 0.07);
  padding: 18rpx var(--page-pad);
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
}

.act {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  font-size: var(--fs-base);
  font-weight: 700;
  letter-spacing: 2rpx;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.act::after {
  border: none;
}

.act:active {
  opacity: 0.9;
  transform: scale(0.99);
}

.act-reject {
  flex: 0 0 220rpx;
  background-color: var(--red-bg);
  color: var(--red);
}

.act-accept {
  background-color: var(--green);
  color: #FFFFFF;
  box-shadow: 0 10rpx 22rpx rgba(90, 158, 111, 0.32);
}

.act-done {
  background-color: var(--accent-dark);
  color: #FFFFFF;
  box-shadow: 0 10rpx 24rpx rgba(232, 85, 117, 0.34);
}

/* ===== 拒绝弹窗 ===== */
.dialog-textarea {
  width: 100%;
  height: 120rpx;
  padding: 16rpx;
  background-color: var(--fill-primary);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  box-sizing: border-box;
  margin-top: 16rpx;
  border: none;
}
