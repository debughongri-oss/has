<view class="admin-bookings">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading}}">
    <!-- 状态筛选（吸顶） -->
    <view class="filter">
      <view class="segs">
        <view
          class="seg tappable {{currentStatus === item.key ? 'seg--on' : ''}}"
          wx:for="{{statusFilters}}"
          wx:key="key"
          bindtap="onFilterChange"
          data-key="{{item.key}}"
        >
          <text class="seg-count {{!item.count ? 'is-zero' : ''}} {{item.key === 'pending' && item.count ? 'is-alert' : ''}}">{{item.count}}</text>
          <text class="seg-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <!-- 快捷入口 -->
    <view class="entries">
      <view class="entry tappable" bindtap="goToCalendar">
        <view class="entry-ic entry-ic--cal"></view>
        <text class="entry-label">日历视图</text>
      </view>
      <view class="entry tappable" bindtap="goToReviews">
        <view class="entry-ic entry-ic--star"></view>
        <text class="entry-label">评价管理</text>
      </view>
    </view>

    <!-- 预约列表 -->
    <view class="list" wx:if="{{bookings.length}}">
      <view
        class="bcard tappable"
        wx:for="{{bookings}}"
        wx:key="_id"
        bindtap="goToDetail"
        data-id="{{item._id}}"
      >
        <view class="bcover">
          <image wx:if="{{item.serviceImage}}" class="bcover-img" src="{{item.serviceImage}}" mode="aspectFill" lazy-load="{{true}}" />
          <view wx:else class="bcover-ph"></view>
        </view>
        <view class="bmain">
          <view class="btop">
            <text class="bsvc text-ellipsis">{{item.service_name}}</text>
            <text class="badge badge--{{item.status}}">{{item.statusLabel}}</text>
          </view>
          <view class="bmeta-row">
            <text class="bwhen">{{item.dateShort}} · {{item.booking_time}}</text>
            <text class="mode-tag {{item.isHomeService ? 'mode-tag--home' : ''}}">{{item.serviceModeLabel}}</text>
            <text class="bcust text-ellipsis" wx:if="{{item.user_info.nickname}}">客户 · {{item.user_info.nickname}}</text>
          </view>
          <text class="bnote text-ellipsis-2" wx:if="{{item.notes}}">备注：{{item.notes}}</text>
        </view>
      </view>
    </view>

    <view class="empty-container" wx:if="{{!bookings.length}}">
      <view class="empty">
        <view class="empty-icon"></view>
        <text class="empty-text">暂无预约</text>
      </view>
    </view>
  </block>
</view>
