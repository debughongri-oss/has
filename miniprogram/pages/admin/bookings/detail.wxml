<view class="page">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading && booking}}">
    <!-- 概要 -->
    <view class="card">
      <text class="status-pill status-pill--{{booking.status}}">{{statusLabel}}</text>
      <text class="h-svc">{{booking.service_name}}</text>
      <view class="h-div"></view>
      <view class="h-row">
        <text class="h-key">日期</text>
        <text class="h-val h-val--accent">{{booking.dateLabel}}</text>
      </view>
      <view class="h-row">
        <text class="h-key">时间</text>
        <text class="h-val h-val--accent">{{booking.booking_time}}</text>
      </view>
      <view class="h-row">
        <text class="h-key">客户</text>
        <text class="h-val">{{booking.user_info.nickname || '微信用户'}}</text>
      </view>
    </view>

    <!-- 客户需求 -->
    <view class="card" wx:if="{{booking.skin_type || booking.special_needs || booking.occasion || booking.notes}}">
      <text class="card-title">客户需求</text>
      <view class="dfield" wx:if="{{booking.skin_type}}">
        <text class="dfield-key">肤质</text>
        <text class="dfield-val">{{booking.skin_type_label || booking.skin_type}}</text>
      </view>
      <view class="dfield" wx:if="{{booking.special_needs}}">
        <text class="dfield-key">特殊需求</text>
        <text class="dfield-val">{{booking.special_needs}}</text>
      </view>
      <view class="dfield" wx:if="{{booking.occasion}}">
        <text class="dfield-key">场合说明</text>
        <text class="dfield-val">{{booking.occasion}}</text>
      </view>
      <view class="dfield" wx:if="{{booking.notes && !booking.skin_type}}">
        <text class="dfield-key">留言</text>
        <text class="dfield-val">{{booking.notes}}</text>
      </view>
    </view>

    <!-- 拒绝原因 -->
    <view class="card" wx:if="{{booking.reject_reason}}">
      <text class="card-title">拒绝原因</text>
      <text class="reason">{{booking.reject_reason}}</text>
    </view>

    <!-- 内部备注 -->
    <view class="card">
      <text class="card-title">内部备注</text>
      <textarea
        class="ta"
        placeholder="仅自己可见，记录沟通要点…"
        placeholder-class="ta-ph"
        value="{{artistNotes}}"
        bindinput="onNotesInput"
        maxlength="500"
      />
      <view class="save-mini tappable" bindtap="saveNotes">保存备注</view>
    </view>
  </block>

  <!-- 操作栏 -->
  <view class="action-bar" wx:if="{{!loading && booking.status === 'pending'}}">
    <button class="act act-reject" bindtap="onReject">拒绝</button>
    <button class="act act-accept" bindtap="onAccept">接受预约</button>
  </view>

  <view class="action-bar" wx:if="{{!loading && booking.status === 'accepted'}}">
    <button class="act act-done" bindtap="onComplete">标记完成</button>
  </view>

  <t-dialog
    visible="{{showRejectDialog}}"
    title="拒绝预约"
    content="请输入拒绝原因"
    confirm-btn="确认拒绝"
    cancel-btn="取消"
    bind:confirm="onRejectConfirm"
    bind:cancel="onRejectCancel"
  >
    <textarea
      slot="content"
      class="dialog-textarea"
      placeholder="输入拒绝原因..."
      value="{{rejectReason}}"
      bindinput="onRejectReasonInput"
    />
  </t-dialog>
</view>
