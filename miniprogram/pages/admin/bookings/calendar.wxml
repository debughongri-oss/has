<view class="calendar-page">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading}}">
    <!-- TDesign Calendar 内嵌模式 -->
    <view class="calendar-wrap">
      <t-calendar
        value="{{calendarValue}}"
        minDate="{{minDate}}"
        format="{{format}}"
        switchMode="month"
        type="single"
        usePopup="{{false}}"
        bind:select="onSelectDate"
      />
    </view>

    <!-- 选中日期的预约 -->
    <view class="day" wx:if="{{selectedDate}}">
      <view class="day-head">
        <text class="day-title">{{selectedDateLabel}}</text>
        <text class="day-count" wx:if="{{dayBookings.length}}">{{dayBookings.length}} 个预约</text>
      </view>

      <view class="busy" wx:if="{{isBusyDay}}">紧凑日程 · 当日 {{busyCount}} 个预约</view>

      <view class="dlist" wx:if="{{dayBookings.length}}">
        <view
          class="dcard tappable"
          wx:for="{{dayBookings}}"
          wx:key="_id"
          bindtap="goToDetail"
          data-id="{{item._id}}"
        >
          <view class="dtime">{{item.booking_time}}</view>
          <view class="dmain">
            <view class="dtop">
              <text class="dsvc text-ellipsis">{{item.service_name}}</text>
              <text class="badge badge--{{item.status}}">{{item.statusLabel}}</text>
            </view>
            <text class="dcust" wx:if="{{item.user_info.nickname}}">客户 · {{item.user_info.nickname}}</text>
          </view>
        </view>
      </view>

      <view class="empty-day" wx:if="{{!dayBookings.length}}">
        <text class="empty-day-text">该日暂无预约</text>
      </view>
    </view>
  </block>
</view>
