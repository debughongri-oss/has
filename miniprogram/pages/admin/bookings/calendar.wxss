.calendar-page {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  /* 让 TDesign 日历的选中态用珊瑚主色 */
  --td-brand-color: #FF6F8B;
  --td-calendar-active-bg-color: #FF6F8B;
}

/* 日历卡 */
.calendar-wrap {
  margin: 24rpx var(--page-pad) 0;
  background-color: var(--bg-elevated);
  border-radius: 26rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

/* 紧凑日程日期标记 — 橙色 */
.calendar-day--busy .t-calendar__control {
  color: var(--orange);
}

/* ===== 当日预约 ===== */
.day {
  padding: 28rpx var(--page-pad) 0;
}

.day-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.day-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
}

.day-count {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.busy {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background-color: var(--orange-bg);
  color: var(--orange);
  font-size: 24rpx;
  font-weight: 600;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.busy::before {
  content: '';
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: var(--orange);
  flex-shrink: 0;
}

.dlist {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dcard {
  display: flex;
  gap: 18rpx;
  align-items: center;
  background-color: var(--bg-elevated);
  border-radius: 22rpx;
  padding: 20rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.dtime {
  flex-shrink: 0;
  background-color: var(--accent-soft);
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: var(--accent);
}

.dmain {
  flex: 1;
  min-width: 0;
}

.dtop {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dsvc {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.badge {
  flex-shrink: 0;
  font-size: 20rpx;
  font-weight: 600;
  padding: 5rpx 16rpx;
  border-radius: 999rpx;
}

.badge--pending {
  background-color: var(--orange-bg);
  color: var(--orange);
}

.badge--accepted {
  background-color: var(--green-bg);
  color: var(--green);
}

.badge--completed {
  background-color: var(--purple-bg);
  color: var(--purple);
}

.badge--cancelled,
.badge--rejected {
  background-color: var(--fill-primary);
  color: var(--text-secondary);
}

.dcust {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

/* ===== 空态 ===== */
.empty-day {
  display: flex;
  justify-content: center;
  padding: 64rpx 0;
}

.empty-day-text {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
}
