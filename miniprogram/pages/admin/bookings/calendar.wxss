.calendar-page {
  min-height: 100vh;
  background-color: var(--bg);
}

.calendar-wrap {
  background-color: var(--bg-elevated);
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
  overflow: hidden;
}

/* 紧凑日程日期标记 — 橙色（per D-23） */
.calendar-day--busy .t-calendar__control {
  color: var(--orange);
}

.day-section {
  padding: 24rpx var(--page-pad);
}

.day-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.day-title {
  font-size: var(--fs-sm);
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 1rpx;
}

.day-count {
  font-size: var(--fs-xs);
  color: var(--text-secondary);
}

/* 紧凑日程警告条（per D-21） */
.busy-warning {
  background-color: var(--orange-bg);
  color: var(--orange);
  font-size: var(--fs-xs);
  font-weight: 500;
  padding: 16rpx 24rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

/* 预约列表 — 复用 admin/bookings/list.wxss 的 card 样式 */
.day-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.card {
  background-color: var(--bg-elevated);
  border-radius: var(--radius-lg);
  padding: var(--page-pad);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.card-svc {
  font-size: var(--fs-sm);
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: 1rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.badge {
  font-size: var(--fs-xs);
  font-weight: 500;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.badge--pending { background-color: var(--orange-bg); color: var(--orange); }
.badge--accepted { background-color: var(--green-bg); color: var(--green); }
.badge--completed { background-color: var(--purple-bg); color: var(--purple); }
.badge--cancelled,
.badge--rejected { background-color: var(--fill-primary); color: var(--text-secondary); }

.card-info {
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  margin-top: 12rpx;
  letter-spacing: 1rpx;
}

.card-note {
  display: block;
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--separator);
  letter-spacing: 1rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.empty-day {
  display: flex;
  justify-content: center;
  padding: 64rpx 0;
}

.empty-day-text {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
}
