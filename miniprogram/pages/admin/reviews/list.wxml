<view class="admin-reviews">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <view class="list" wx:if="{{!loading && reviews.length}}">
    <view class="card" wx:for="{{reviews}}" wx:key="_id">
      <view class="rtop">
        <text class="rname">{{item.user_nickname || '匿名用户'}}</text>
        <text class="rtime">{{item.timeLabel}}</text>
      </view>
      <view class="rrate">
        <view class="stars">
          <text class="stars-bg">★★★★★</text>
          <text class="stars-fg" style="width:{{item.rating / 5 * 100}}%">★★★★★</text>
        </view>
        <text class="rsvc" wx:if="{{item.service_name}}">{{item.service_name}}</text>
      </view>
      <text class="rcontent" wx:if="{{item.content}}">{{item.content}}</text>
    </view>
  </view>

  <view class="empty-container" wx:if="{{!loading && !reviews.length}}">
    <view class="empty">
      <view class="empty-icon"></view>
      <text class="empty-text">暂无评价</text>
    </view>
  </view>
</view>
