<view class="admin-reviews">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <!-- 概览统计：平均分 + 总数 -->
  <view class="stats-bar" wx:if="{{!loading && stats}}">
    <view class="stats-zone">
      <view class="stats-numrow">
        <text class="stats-avg">{{stats.average}}</text>
        <text class="stats-max">/ 5.0</text>
      </view>
      <view class="stats-stars">
        <text class="stars-bg">★★★★★</text>
        <text class="stars-fg" style="width:{{stats.average / 5 * 100}}%">★★★★★</text>
      </view>
      <text class="stats-sub">平均评分</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-zone stats-zone--count">
      <text class="stats-total">{{stats.total}}</text>
      <text class="stats-sub">条客户评价</text>
    </view>
  </view>

  <!-- REVW-13: 筛选控制条（吸顶 · ADM-01: 默认只显示评分段，标签/排序折叠） -->
  <view class="filter-bar" wx:if="{{!loading}}">
    <view class="filter-group filter-group--primary">
      <scroll-view class="segs" scroll-x enable-flex>
        <view
          class="seg tappable {{currentRating === item.key ? 'seg--on' : ''}}"
          wx:for="{{ratingSegs}}"
          wx:key="key"
          bindtap="onRatingSeg"
          data-key="{{item.key}}"
        >
          <text class="seg-label">{{item.label}}</text>
        </view>
      </scroll-view>
      <view
        class="filter-toggle tappable {{filterExpanded ? 'filter-toggle--on' : ''}}"
        bindtap="onToggleFilterExpand"
      >
        <text class="filter-toggle-label">筛选</text>
        <text class="filter-toggle-arrow">{{filterExpanded ? '⌃' : '⌄'}}</text>
        <view class="filter-toggle-badge" wx:if="{{currentTag || sortBy !== 'latest'}}">·</view>
      </view>
    </view>

    <block wx:if="{{filterExpanded}}">
      <view class="filter-group">
        <text class="filter-label">标签</text>
        <scroll-view class="segs" scroll-x enable-flex>
          <view
            class="seg tappable {{currentTag === item.key ? 'seg--on' : ''}}"
            wx:for="{{tagSegs}}"
            wx:key="key"
            bindtap="onTagSeg"
            data-key="{{item.key}}"
          >
            <text class="seg-label">{{item.label}}</text>
          </view>
        </scroll-view>
      </view>

      <view class="sort-row">
        <text class="sort-label">排序</text>
        <view
          class="sort-opt tappable {{sortBy === item.key ? 'sort-opt--on' : ''}}"
          wx:for="{{sortOptions}}"
          wx:key="key"
          bindtap="onSortChange"
          data-key="{{item.key}}"
        >{{item.label}}</view>
      </view>
    </block>
  </view>

  <view class="list" wx:if="{{!loading && reviews.length}}">
    <view class="card card--{{item.ratingTier}}" wx:for="{{reviews}}" wx:key="_id">
      <view class="rtop">
        <view class="rname-wrap">
          <text class="rname">{{item.user_nickname || '匿名用户'}}</text>
          <!-- REVW-12/D-12: 后台仍显示真实昵称，但加「匿名」徽标提示该评价对客户侧匿名 -->
          <text class="anon-mark" wx:if="{{item.isAnonymous}}">匿名</text>
          <!-- 待回复：引导化妆师优先处理未回复评价 -->
          <text class="pending-mark" wx:if="{{!item.artist_reply}}">待回复</text>
        </view>
        <text class="rtime">{{item.timeLabel}}</text>
      </view>
      <view class="rrate">
        <view class="stars">
          <text class="stars-bg">★★★★★</text>
          <text class="stars-fg" style="width:{{item.rating / 5 * 100}}%">★★★★★</text>
        </view>
        <text class="rsvc" wx:if="{{item.service_name}}">{{item.service_name}}</text>
      </view>

      <!-- REVW-10: 标签 chips -->
      <view class="rtags" wx:if="{{item.tagLabels.length}}">
        <text class="rtag" wx:for="{{item.tagLabels}}" wx:for-item="tl" wx:key="*this">{{tl}}</text>
      </view>

      <text class="rcontent" wx:if="{{item.content}}">{{item.content}}</text>

      <!-- REVW-11: 评价图片缩略图（点击 wx.previewImage 全屏查看） -->
      <view class="rthumbs" wx:if="{{item.thumb}}">
        <image
          class="rthumb"
          wx:for="{{item.images}}"
          wx:for-item="img"
          wx:key="*this"
          src="{{img}}"
          mode="aspectFill"
          bindtap="onPreviewImage"
          data-url="{{img}}"
          data-id="{{item._id}}"
        ></image>
      </view>

      <!-- 化妆师回复展示 (REVW-09) -->
      <view class="reply-display" wx:if="{{item.artist_reply}}">
        <view class="reply-label">化妆师回复</view>
        <text class="reply-text">{{item.artist_reply}}</text>
      </view>

      <view class="card-actions" wx:if="{{replyingId !== item._id}}">
        <!-- ADM-02: 显式按钮替代文字链接，触控区 80+rpx -->
        <view class="action-btn action-btn--reply tappable" bindtap="onToggleReply" data-id="{{item._id}}">
          <text>{{item.artist_reply ? '修改回复' : '写回复'}}</text>
        </view>
        <view
          class="action-btn action-btn--delete tappable {{deletingId === item._id ? 'action-btn--disabled' : ''}}"
          bindtap="onDeleteReview"
          data-id="{{item._id}}"
        >
          <text>{{deletingId === item._id ? '删除中...' : '删除'}}</text>
        </view>
      </view>

      <!-- 回复编辑器 (REVW-08 · ADM-02: 显式 3 按钮) -->
      <view class="reply-editor" wx:if="{{replyingId === item._id}}">
        <textarea
          class="reply-input"
          placeholder="输入回复内容..."
          placeholder-class="reply-ph"
          value="{{replyText}}"
          maxlength="200"
          bindinput="onReplyInput"
          auto-height
        />
        <view class="reply-actions">
          <view class="reply-action-btn reply-action-btn--cancel tappable" bindtap="onToggleReply" data-id="{{item._id}}">
            <text>取消</text>
          </view>
          <view class="reply-action-btn reply-action-btn--delete tappable" wx:if="{{item.artist_reply}}" bindtap="onDeleteReply">
            <text>删除回复</text>
          </view>
          <view class="reply-action-btn reply-action-btn--save tappable {{replySubmitting ? 'reply-action-btn--disabled' : ''}}" bindtap="onSubmitReply">
            <text>{{replySubmitting ? '提交中...' : '保存回复'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-container" wx:if="{{!loading && !reviews.length}}">
    <view class="empty">
      <view class="empty-icon"></view>
      <text class="empty-text">暂无评价</text>
    </view>
  </view>
</view>
