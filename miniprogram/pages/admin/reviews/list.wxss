.admin-reviews {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ===== 概览统计 ===== */
.stats-bar {
  display: flex;
  align-items: center;
  margin: 24rpx var(--page-pad) 4rpx;
  padding: 28rpx 32rpx;
  background-color: var(--bg-elevated);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.stats-zone {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.stats-zone--count {
  align-items: flex-end;
}

.stats-numrow {
  display: flex;
  align-items: baseline;
}

.stats-avg {
  font-size: 60rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1;
  letter-spacing: -1rpx;
}

.stats-max {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-left: 6rpx;
}

.stats-total {
  font-size: 52rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1;
  letter-spacing: -1rpx;
}

.stats-sub {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 12rpx;
}

.stats-divider {
  width: 1rpx;
  height: 64rpx;
  background-color: var(--separator-opaque);
  margin: 0 36rpx;
}

.stats-stars {
  position: relative;
  display: inline-block;
  font-size: 26rpx;
  line-height: 1;
  letter-spacing: 4rpx;
  margin-top: 14rpx;
  white-space: nowrap;
}

/* ===== REVW-13: 筛选 + 排序控制条（吸顶） ===== */
.filter-bar {
  position: sticky;
  top: 0;
  z-index: 20;
  padding: 8rpx var(--page-pad) 12rpx;
  background-color: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(12rpx);
  border-bottom: 1rpx solid var(--separator);
}

/* ADM-01: 主行 = 评分段 + 折叠按钮，单行紧凑 */
.filter-group {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 0;
}

.filter-group--primary {
  padding: 8rpx 0;
}

.filter-label {
  flex-shrink: 0;
  width: 56rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-tertiary);
  letter-spacing: 1rpx;
}

.segs {
  display: flex;
  white-space: nowrap;
  gap: 12rpx;
  flex: 1;
}

.seg {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background-color: var(--fill-primary);
  flex-shrink: 0;
}

.seg-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.seg--on {
  background-color: var(--accent);
}

.seg--on .seg-label {
  color: #FFFFFF;
}

/* ADM-01: 筛选折叠按钮 */
.filter-toggle {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background-color: var(--fill-primary);
  flex-shrink: 0;
  position: relative;
}

.filter-toggle--on {
  background-color: var(--gold-bg);
}

.filter-toggle-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-secondary);
}

.filter-toggle--on .filter-toggle-label {
  color: #A78247;
}

.filter-toggle-arrow {
  font-size: 18rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

.filter-toggle--on .filter-toggle-arrow {
  color: #A78247;
}

/* 角标：当前有非默认筛选时给个点提示 */
.filter-toggle-badge {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: var(--accent);
}

.sort-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 12rpx 0 4rpx;
}

.sort-label {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-tertiary);
  letter-spacing: 1rpx;
}

.sort-opt {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 4rpx 0;
}

.sort-opt--on {
  color: var(--accent);
  font-weight: 700;
  border-bottom: 3rpx solid var(--accent);
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx var(--page-pad);
}

.card {
  position: relative;
  background-color: var(--bg-elevated);
  border-radius: 24rpx;
  padding: 26rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

/* 情感分级左色条：good 绿 / mid 金 / low 红 — 一眼扫到需关注的差评 */
.card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 28rpx;
  bottom: 28rpx;
  width: 6rpx;
  border-radius: 0 6rpx 6rpx 0;
  background-color: var(--separator-opaque);
}

.card--good::before {
  background-color: var(--green);
}

.card--mid::before {
  background-color: var(--gold);
}

.card--low::before {
  background-color: var(--red);
}

.rtop {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rname-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.rname {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* REVW-12/D-12: 匿名评价标记（后台仍显示真实昵称） */
.anon-mark {
  font-size: 18rpx;
  color: var(--gold);
  background-color: var(--gold-bg);
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  line-height: 1.4;
}

/* 待回复：引导优先处理未回复评价 */
.pending-mark {
  font-size: 18rpx;
  color: var(--accent-dark);
  background-color: var(--accent-soft);
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  line-height: 1.4;
}

.rtime {
  font-size: 22rpx;
  color: var(--text-tertiary);
  flex-shrink: 0;
  margin-left: 12rpx;
}

.rrate {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 14rpx;
}

.rsvc {
  font-size: 20rpx;
  color: var(--accent);
  background-color: var(--accent-soft);
  padding: 5rpx 16rpx;
  border-radius: 999rpx;
}

/* REVW-10: 标签 chips */
.rtags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.rtag {
  font-size: 20rpx;
  color: var(--text-secondary);
  background-color: var(--fill-primary);
  border: 1rpx solid var(--separator);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  line-height: 1.5;
}

.rcontent {
  display: block;
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.7;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--separator);
}

/* REVW-11: 评价图片缩略图 */
.rthumbs {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.rthumb {
  width: 130rpx;
  height: 130rpx;
  border-radius: 12rpx;
  background-color: var(--bg);
}

/* ADM-02: 显式按钮替代文字链接，触控区 80+rpx */
.card-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--separator);
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
}

/* 写回复 / 修改回复：粉色实心（主操作） */
.action-btn--reply {
  background-color: var(--accent);
  color: #FFFFFF;
  box-shadow: 0 3rpx 10rpx rgba(255, 111, 139, 0.28);
}

/* 删除：red-bg token（ADM-03: 替换硬编码 #D9534F） */
.action-btn--delete {
  flex: 0 0 140rpx;
  background-color: var(--red-bg);
  color: var(--red);
}

.action-btn--disabled {
  opacity: 0.5;
}

/* 化妆师回复展示 (REVW-09) */
.reply-display {
  margin-top: 16rpx;
  padding: 18rpx 22rpx;
  background-color: var(--fill-primary);
  border-radius: var(--radius-sm);
  border-left: 4rpx solid var(--accent);
}

.reply-label {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--accent);
  margin-bottom: 8rpx;
}

.reply-text {
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  line-height: 1.6;
}

/* ADM-02: 回复编辑器 — 3 显式按钮 */
.reply-editor {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.reply-input {
  width: 100%;
  min-height: 80rpx;
  padding: 18rpx 22rpx;
  font-size: var(--fs-xs);
  color: var(--text-primary);
  background-color: var(--fill-primary);
  border-radius: 14rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.reply-ph {
  color: var(--text-tertiary);
}

.reply-actions {
  display: flex;
  gap: 10rpx;
  justify-content: flex-end;
}

.reply-action-btn {
  padding: 12rpx 24rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.4;
}

.reply-action-btn--cancel {
  background-color: var(--fill-primary);
  color: var(--text-secondary);
}

.reply-action-btn--delete {
  background-color: var(--red-bg);
  color: var(--red);
}

.reply-action-btn--save {
  background-color: var(--accent);
  color: #FFFFFF;
  padding: 12rpx 36rpx;
}

.reply-action-btn--disabled {
  opacity: 0.5;
}

.empty-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 50vh;
}
