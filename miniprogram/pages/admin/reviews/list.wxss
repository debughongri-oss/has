.admin-reviews {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx var(--page-pad);
}

.card {
  background-color: var(--bg-elevated);
  border-radius: 24rpx;
  padding: 26rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.rtop {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rname {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.rtime {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.rrate {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 14rpx;
}

.rsvc {
  font-size: 20rpx;
  color: var(--accent);
  background-color: var(--accent-soft);
  padding: 5rpx 16rpx;
  border-radius: 999rpx;
}

.rcontent {
  display: block;
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.7;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--separator);
}

/* 化妆师回复展示 (REVW-09) */
.reply-display {
  margin-top: 16rpx;
  padding: 18rpx 22rpx;
  background-color: var(--fill-primary);
  border-radius: var(--radius-sm);
  border-left: 4rpx solid var(--accent);
}

.reply-label {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--accent);
  margin-bottom: 8rpx;
}

.reply-text {
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  line-height: 1.6;
}

/* 回复操作按钮 */
.reply-action {
  margin-top: 14rpx;
  align-self: flex-start;
  font-size: 22rpx;
  color: var(--accent);
  padding: 6rpx 0;
}

/* 回复编辑器 (REVW-08) */
.reply-editor {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.reply-input {
  width: 100%;
  min-height: 80rpx;
  padding: 18rpx 22rpx;
  font-size: var(--fs-xs);
  color: var(--text-primary);
  background-color: var(--fill-primary);
  border-radius: var(--radius-sm);
  line-height: 1.6;
  box-sizing: border-box;
}

.reply-ph {
  color: var(--text-tertiary);
}

.reply-submit {
  align-self: flex-end;
  font-size: 24rpx;
  color: #FFFFFF;
  background-color: var(--accent-dark);
  padding: 12rpx 36rpx;
  border-radius: var(--radius-sm);
  line-height: 1.4;
  border: none;
}

.reply-submit::after {
  border: none;
}

.reply-submit[disabled] {
  opacity: 0.5;
}

.empty-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 50vh;
}
