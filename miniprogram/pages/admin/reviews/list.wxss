.admin-reviews {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx var(--page-pad);
}

.card {
  background-color: var(--bg-elevated);
  border-radius: 24rpx;
  padding: 26rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.rtop {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.rname {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.rtime {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.rrate {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 14rpx;
}

.rsvc {
  font-size: 20rpx;
  color: var(--accent);
  background-color: var(--accent-soft);
  padding: 5rpx 16rpx;
  border-radius: 999rpx;
}

.rcontent {
  display: block;
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.7;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid var(--separator);
}

.empty-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 50vh;
}
