.edit-profile {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: 200rpx;
}

.avatar-area {
  margin-top: 16rpx;
}

.avatar-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--page-pad);
  background-color: var(--bg-elevated);
  margin: 0 var(--page-pad);
  border-radius: var(--radius-lg);
}

.key {
  font-size: 28rpx;
  color: var(--text-primary);
  flex-shrink: 0;
  width: 100rpx;
  letter-spacing: 1rpx;
}

.avatar-picker {
  display: flex;
  align-items: center;
}

.avatar-preview {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: block;
}

.avatar-ph {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: var(--fill-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-ph-text {
  font-size: 36rpx;
  color: var(--text-tertiary);
}

.group {
  background-color: var(--bg-elevated);
  margin: 16rpx var(--page-pad) 0;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.row {
  display: flex;
  align-items: center;
  padding: 0 var(--page-pad);
  min-height: 96rpx;
  border-bottom: 1rpx solid var(--separator);
}

.row:last-child {
  border-bottom: none;
}

.row--col {
  flex-direction: column;
  align-items: stretch;
  padding: var(--page-pad);
}

.val {
  flex: 1;
  height: 96rpx;
  font-size: 28rpx;
  text-align: right;
  color: var(--text-primary);
  padding: 0;
  letter-spacing: 1rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.textarea {
  width: 100%;
  height: 160rpx;
  background-color: var(--fill-secondary);
  border-radius: var(--radius-md);
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.7;
  border: none;
  letter-spacing: 1rpx;
}

.save-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx var(--page-pad);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: var(--bg-elevated);
  border-top: 1rpx solid var(--separator);
}

.save-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background-color: var(--accent);
  color: #fff;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  border: none;
}

.save-btn::after {
  border: none;
}

.save-btn[disabled] {
  opacity: 0.4;
}
