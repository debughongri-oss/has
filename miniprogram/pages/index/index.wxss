.page-home {
  min-height: 100vh;
  background-color: #FBFAF8;
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
}

/* ===== 专业档案头 ===== */
.profile-hero {
  display: flex;
  align-items: center;
  gap: 34rpx;
  padding: 46rpx var(--page-pad) 28rpx;
}

.profile-avatar {
  width: 144rpx;
  height: 144rpx;
  flex-shrink: 0;
  border-radius: 50%;
  overflow: hidden;
  background-color: #F1EAE5;
  box-shadow: 0 0 0 1rpx rgba(0, 0, 0, 0.04);
}

.avatar-fallback {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #DFA0AA, #B98266);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-fallback text {
  font-size: 58rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.profile-main {
  flex: 1;
  min-width: 0;
}

.profile-name {
  display: block;
  font-size: 52rpx;
  line-height: 1.14;
  font-weight: 800;
  color: #111111;
}

.profile-role {
  display: block;
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.3;
  color: rgba(0, 0, 0, 0.58);
  font-weight: 500;
}

.profile-rule {
  width: 70rpx;
  height: 3rpx;
  margin-top: 18rpx;
  background-color: var(--gold);
}

.profile-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.profile-meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 25rpx;
  color: rgba(0, 0, 0, 0.68);
  line-height: 1.4;
}

.profile-meta-item--rating {
  color: var(--accent-dark);
}

.profile-meta-sep {
  width: 1rpx;
  height: 26rpx;
  background-color: rgba(0, 0, 0, 0.16);
}

.meta-label {
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  background-color: rgba(201, 169, 110, 0.12);
  color: #A78247;
  font-size: 19rpx;
  font-weight: 700;
}

.meta-label--rating {
  background-color: rgba(255, 111, 139, 0.10);
  color: var(--accent-dark);
}

/* ===== 章节标题 ===== */
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 0 var(--page-pad);
  margin: 54rpx 0 24rpx;
}

.section-head--portfolio {
  margin-top: 26rpx;
}

.section-label {
  display: block;
  font-size: 42rpx;
  line-height: 1.12;
  font-weight: 800;
  color: #111111;
}

.section-rule {
  width: 48rpx;
  height: 3rpx;
  margin-top: 16rpx;
  background-color: var(--gold);
}

.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding-top: 8rpx;
  font-size: 25rpx;
  color: rgba(0, 0, 0, 0.64);
}

.section-more-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 3rpx solid rgba(0, 0, 0, 0.42);
  border-right: 3rpx solid rgba(0, 0, 0, 0.42);
  transform: rotate(45deg);
  margin-left: 4rpx;
}

/* ===== 作品拼贴 ===== */
.mosaic {
  display: flex;
  gap: 10rpx;
  padding: 0 var(--page-pad);
  height: 540rpx;
}

.mosaic-main,
.mosaic-small {
  position: relative;
  overflow: hidden;
  background-color: #F2EEE9;
}

.mosaic-main {
  flex: 1.18;
}

.mosaic-side {
  flex: 0.82;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.mosaic-small {
  flex: 1;
}

.mosaic-img {
  width: 100%;
  height: 100%;
  display: block;
}

.mosaic-caption {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 48rpx 24rpx 22rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.52), rgba(0, 0, 0, 0));
}

.mosaic-title {
  display: block;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
}

.mosaic-cat {
  display: inline-block;
  margin-top: 8rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background-color: rgba(255, 255, 255, 0.22);
  color: #FFFFFF;
  font-size: 20rpx;
}

/* ===== 分类 chips ===== */
.chips {
  white-space: nowrap;
  padding: 36rpx var(--page-pad) 0;
}

.chip {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.66);
  background-color: #FFFFFF;
  padding: 13rpx 28rpx;
  border-radius: 999rpx;
  margin-right: 14rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
}

/* ===== 热门服务 ===== */
.svc-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 var(--page-pad);
}

.svc-card {
  position: relative;
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 30rpx 30rpx 30rpx 34rpx;
  background-color: #FFFFFF;
  border-radius: var(--radius-lg);
  box-shadow: 0 4rpx 20rpx rgba(60, 40, 30, 0.06);
  overflow: hidden;
}

.svc-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 24rpx;
  bottom: 24rpx;
  width: 6rpx;
  border-radius: 0 6rpx 6rpx 0;
  background: linear-gradient(to bottom, var(--gold), #DDBE82);
}

.svc-rank {
  flex-shrink: 0;
  width: 44rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: var(--gold);
  letter-spacing: 1rpx;
}

.svc-main {
  flex: 1;
  min-width: 0;
}

.svc-name {
  display: block;
  font-size: 31rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #17151A;
}

.svc-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.45;
  color: rgba(0, 0, 0, 0.46);
}

.svc-pricebox {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
}

.svc-price {
  display: flex;
  align-items: baseline;
  color: var(--accent-dark);
}

.svc-price-sym {
  font-size: 21rpx;
  font-weight: 700;
}

.svc-price-num {
  font-size: 38rpx;
  font-weight: 800;
}

.svc-from {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: rgba(0, 0, 0, 0.34);
}

/* ===== 客户评价 ===== */
.review-card {
  position: relative;
  margin: 0 var(--page-pad);
  padding: 32rpx 32rpx 30rpx;
  background-color: #FFFFFF;
  border-radius: var(--radius-xl);
  box-shadow: 0 4rpx 20rpx rgba(60, 40, 30, 0.06);
  overflow: hidden;
}

.review-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 6rpx;
  background: linear-gradient(to right, var(--gold), var(--accent));
}

.review-top {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.review-score {
  display: flex;
  align-items: baseline;
}

.review-avg {
  font-size: 64rpx;
  font-weight: 800;
  color: #17151A;
  line-height: 1;
}

.review-max {
  margin-left: 4rpx;
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.34);
}

.review-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-start;  /* v2.3-r2 fix: 防止 .stars 被 column flex 默认 stretch 撑宽 */
  gap: 8rpx;
}

.review-count {
  font-size: 23rpx;
  color: rgba(0, 0, 0, 0.52);
}

.review-quote {
  position: relative;
  margin-top: 26rpx;
  padding: 4rpx 0 4rpx 26rpx;
  border-left: 4rpx solid var(--gold);
}

.review-quote-text {
  display: block;
  font-size: 27rpx;
  color: #17151A;
  line-height: 1.8;
}

.review-quote-from {
  display: block;
  margin-top: 14rpx;
  font-size: 23rpx;
  color: rgba(0, 0, 0, 0.54);
}

.review-reply {
  margin-top: 22rpx;
  padding: 18rpx 22rpx;
  background-color: var(--accent-light);
  border-radius: var(--radius-md);
}

.review-reply-label {
  display: block;
  font-size: 21rpx;
  font-weight: 700;
  color: var(--accent-dark);
  margin-bottom: 6rpx;
}

.review-reply-text {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.58);
  line-height: 1.6;
}

/* REVW-10/D-04: 大家这样说 — 高频标签云（按热度分级） */
.tag-cloud {
  margin-top: 20rpx;
  padding: 26rpx 28rpx 28rpx;
  background-color: var(--bg-elevated);
  border-radius: 22rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.tag-cloud-head {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 18rpx;
}

.tag-cloud-quote {
  font-size: 38rpx;
  line-height: 1;
  color: var(--gold);
  font-weight: 700;
}

.tag-cloud-title {
  font-size: 24rpx;
  color: var(--text-secondary);
  letter-spacing: 1rpx;
}

.tag-cloud-list {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 14rpx;
}

.cloud-chip {
  display: inline-flex;
  align-items: baseline;
  border-radius: 999rpx;
}

/* normal：轻描淡写 */
.cloud-chip--normal {
  padding: 8rpx 20rpx;
  background-color: var(--gold-bg);
  border: 1rpx solid rgba(201, 169, 110, 0.22);
}

.cloud-chip--normal .cloud-chip-label {
  font-size: 24rpx;
  font-weight: 500;
}

/* warm：中等强调 */
.cloud-chip--warm {
  padding: 11rpx 24rpx;
  background-color: rgba(201, 169, 110, 0.16);
  border: 1rpx solid rgba(201, 169, 110, 0.4);
}

.cloud-chip--warm .cloud-chip-label {
  font-size: 27rpx;
  font-weight: 600;
}

/* hot：最热标签 · 金色实心 */
.cloud-chip--hot {
  padding: 13rpx 28rpx;
  background: linear-gradient(135deg, var(--gold), #DDBE82);
  border: 1rpx solid transparent;
  box-shadow: 0 6rpx 16rpx rgba(201, 169, 110, 0.34);
}

.cloud-chip--hot .cloud-chip-label {
  font-size: 29rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.cloud-chip--hot .cloud-chip-count {
  color: rgba(255, 255, 255, 0.82);
}

.cloud-chip-label {
  color: var(--text-primary);
}

.cloud-chip-count {
  font-size: 22rpx;
  color: var(--gold);
  margin-left: 4rpx;
}

.stars {
  position: relative;
  display: inline-block;
  font-size: 26rpx;
  line-height: 1;
  letter-spacing: 4rpx;
  white-space: nowrap;
}

.stars--sm {
  font-size: 20rpx;
  letter-spacing: 2rpx;
}

.stars-bg {
  color: rgba(0, 0, 0, 0.12);
}

.stars-fg {
  position: absolute;
  top: 0;
  left: 0;
  color: var(--gold);
  overflow: hidden;
  white-space: nowrap;
}

/* ===== v2.3-r2: 评分分布条 ===== */
.dist {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid var(--separator);
}

.dist-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.dist-star {
  width: 56rpx;
  font-size: 21rpx;
  color: var(--text-tertiary);
  font-weight: 600;
  flex-shrink: 0;
}

.dist-track {
  flex: 1;
  height: 10rpx;
  background-color: rgba(0, 0, 0, 0.05);
  border-radius: 999rpx;
  overflow: hidden;
}

.dist-fill {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.4s ease;
}

/* 5★ 实金渐变（最强证据），4★ 中金，3★ 弱金，1-2★ 灰 */
.dist-fill--5 {
  background: linear-gradient(to right, var(--gold), #DDBE82);
}
.dist-fill--4 {
  background: rgba(201, 169, 110, 0.55);
}
.dist-fill--3 {
  background: rgba(201, 169, 110, 0.32);
}
.dist-fill--2,
.dist-fill--1 {
  background: rgba(0, 0, 0, 0.18);
}

.dist-count {
  width: 56rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: right;
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}

/* ===== v2.3-r2: 作品×评价联动 — featured testimonial ===== */
.featured-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin: 16rpx var(--page-pad) 0;
}

.featured-card {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  padding: 20rpx;
  background-color: var(--bg-elevated);
  border-radius: 22rpx;
  box-shadow: 0 4rpx 16rpx rgba(60, 40, 30, 0.05);
}

.featured-thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 14rpx;
  overflow: hidden;
  flex-shrink: 0;
  background-color: var(--gold-bg);
}

.featured-thumb-img {
  width: 100%;
  height: 100%;
  display: block;
}

.featured-thumb--ph {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--gold-bg), rgba(255, 111, 139, 0.08));
}

.featured-thumb-initial {
  font-size: 20rpx;
  color: var(--gold);
  font-weight: 700;
  text-align: center;
  line-height: 1.2;
  padding: 4rpx;
}

.featured-body {
  flex: 1;
  min-width: 0;
}

.featured-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.featured-svc {
  font-size: 19rpx;
  font-weight: 700;
  color: var(--accent);
  background-color: var(--accent-soft);
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.featured-quote {
  display: block;
  font-size: 25rpx;
  color: var(--text-primary);
  line-height: 1.55;
  margin-top: 8rpx;
}

.featured-from {
  display: block;
  font-size: 21rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

/* ===== v2.3-r2: CTA 主次分明（预约 dominant + 联系次） ===== */
.cta-panel {
  margin: 44rpx var(--page-pad) 0;
}

.cta-stack {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.cta-book,
.cta-contact {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.cta-book {
  height: 100rpx;
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  background: linear-gradient(135deg, #FF6F8B 0%, #E85575 100%);
  color: #FFFFFF;
  border-radius: var(--radius-md);
  box-shadow: 0 10rpx 24rpx rgba(232, 85, 117, 0.34);
}

.cta-contact {
  height: 72rpx;
  font-size: 26rpx;
  font-weight: 600;
  background-color: #FFFFFF;
  color: var(--text-primary);
  border: 1rpx solid rgba(0, 0, 0, 0.1);
  border-radius: var(--radius-md);
}

.cta-book::after,
.cta-contact::after {
  border: none;
}

/* ===== 错误态 ===== */
.error-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 50vh;
  gap: 32rpx;
}

.error-text {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
}

.error-retry {
  color: var(--accent);
  font-size: var(--fs-sm);
  font-weight: 600;
}
