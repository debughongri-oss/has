<view class="page-home">
  <privacy-popup bind:agree="onPrivacyAgree" />

  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading && artist}}">
    <!-- 专业档案头 -->
    <view class="profile-hero">
      <view class="profile-avatar">
        <t-image
          wx:if="{{artist.avatar}}"
          src="{{artist.avatar}}"
          mode="aspectFill"
          width="144rpx"
          height="144rpx"
          shape="circle"
        />
        <view class="avatar-fallback" wx:else>
          <text>{{artist.name[0] || '妆'}}</text>
        </view>
      </view>
      <view class="profile-main">
        <text class="profile-name">{{artist.name}}</text>
        <text class="profile-role">Makeup Artist</text>
        <view class="profile-rule"></view>
        <view class="profile-meta">
          <view class="profile-meta-item" wx:if="{{artist.contact_info && artist.contact_info.location}}">
            <text class="meta-label">地点</text>
            <text>{{artist.contact_info.location}}</text>
          </view>
          <view class="profile-meta-sep" wx:if="{{artist.contact_info && artist.contact_info.location && (artist.experience_years || artist.experience)}}"></view>
          <view class="profile-meta-item" wx:if="{{artist.experience_years || artist.experience}}">
            <text class="meta-label">经验</text>
            <text>{{artist.experience_years ? artist.experience_years + '年经验' : artist.experience}}</text>
          </view>
          <view class="profile-meta-sep" wx:if="{{reviewStats && reviewStats.total > 0}}"></view>
          <view class="profile-meta-item profile-meta-item--rating" wx:if="{{reviewStats && reviewStats.total > 0}}">
            <text class="meta-label meta-label--rating">评分</text>
            <text>{{reviewStats.average}}评分</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 精选作品拼贴 -->
    <view class="portfolio" wx:if="{{heroWork}}">
      <view class="section-head section-head--portfolio">
        <view>
          <text class="section-label">精选作品</text>
          <view class="section-rule"></view>
        </view>
        <view class="section-more tappable" bindtap="goToWorks">
          <text>看作品</text>
          <view class="section-more-arrow"></view>
        </view>
      </view>
      <view class="mosaic">
        <view
          class="mosaic-main tappable"
          bindtap="goToWorkDetail"
          data-id="{{heroWork._id}}"
        >
          <image class="mosaic-img" src="{{heroWork.images[0]}}" mode="aspectFill" lazy-load />
          <view class="mosaic-caption">
            <text class="mosaic-title text-ellipsis">{{heroWork.title}}</text>
            <text class="mosaic-cat" wx:if="{{heroWork.categoryLabel}}">{{heroWork.categoryLabel}}</text>
          </view>
        </view>
        <view class="mosaic-side" wx:if="{{mosaicWorks.length}}">
          <view
            class="mosaic-small tappable"
            wx:for="{{mosaicWorks}}"
            wx:key="_id"
            bindtap="goToWorkDetail"
            data-id="{{item._id}}"
          >
            <image class="mosaic-img" src="{{item.images[0]}}" mode="aspectFill" lazy-load />
          </view>
        </view>
      </view>
    </view>

    <!-- 分类快捷入口 -->
    <scroll-view class="chips" scroll-x enhanced show-scrollbar="{{false}}">
      <view
        class="chip tappable"
        wx:for="{{categories}}"
        wx:key="key"
        bindtap="goToCategory"
        data-key="{{item.key}}"
      >{{item.label}}</view>
    </scroll-view>

    <!-- 热门服务 -->
    <view class="svc" wx:if="{{services.length}}">
      <view class="section-head">
        <view>
          <text class="section-label">热门服务</text>
          <view class="section-rule"></view>
        </view>
        <view class="section-more tappable" bindtap="goToServices">
          <text>全部</text>
          <view class="section-more-arrow"></view>
        </view>
      </view>
      <view class="svc-stack">
        <view
          class="svc-card tappable"
          wx:for="{{services}}"
          wx:key="_id"
          bindtap="goToServices"
        >
          <text class="svc-rank">{{index + 1 < 10 ? '0' : ''}}{{index + 1}}</text>
          <view class="svc-main">
            <text class="svc-name text-ellipsis">{{item.name}}</text>
            <text class="svc-meta">{{item.meta}}</text>
          </view>
          <view class="svc-pricebox">
            <view class="svc-price">
              <text class="svc-price-sym">¥</text>
              <text class="svc-price-num">{{item.price}}</text>
            </view>
            <text class="svc-from">起</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 客户评价 -->
    <view class="reviews" wx:if="{{reviewStats && reviewStats.total > 0}}">
      <view class="section-head">
        <view>
          <text class="section-label">客户评价</text>
          <view class="section-rule"></view>
        </view>
        <view class="section-more tappable" bindtap="goToAllReviews">
          <text>查看全部 {{reviewStats.total}} 条</text>
          <view class="section-more-arrow"></view>
        </view>
      </view>

      <!-- v2.3-r2: 评分概览 + 分布条（不可造假的证据） -->
      <view class="review-card">
        <view class="review-top">
          <view class="review-score">
            <text class="review-avg">{{reviewStats.average}}</text>
            <text class="review-max">/ 5.0</text>
          </view>
          <view class="review-meta">
            <view class="stars">
              <text class="stars-bg">★★★★★</text>
              <text class="stars-fg" style="width:{{reviewStats.average / 5 * 100}}%">★★★★★</text>
            </view>
            <text class="review-count">{{reviewStats.total}} 条真实评价</text>
          </view>
        </view>

        <!-- v2.3-r2: 评分分布条 -->
        <view class="dist" wx:if="{{reviewStats.distribution && reviewStats.distribution.length}}">
          <view class="dist-row" wx:for="{{reviewStats.distribution}}" wx:key="star">
            <text class="dist-star">{{item.star}}★</text>
            <view class="dist-track">
              <view class="dist-fill dist-fill--{{item.star}}" style="width:{{item.percent}}%"></view>
            </view>
            <text class="dist-count">{{item.count}}</text>
          </view>
        </view>
      </view>

      <!-- v2.3-r2: 作品×评价联动 — 精选 testimonial 配作品缩略图 -->
      <view class="featured-list" wx:if="{{reviewStats.featured && reviewStats.featured.length}}">
        <view class="featured-card" wx:for="{{reviewStats.featured}}" wx:key="created_at">
          <view class="featured-thumb" wx:if="{{item.service_cover}}">
            <image class="featured-thumb-img" src="{{item.service_cover}}" mode="aspectFill" lazy-load />
          </view>
          <view class="featured-thumb featured-thumb--ph" wx:else>
            <text class="featured-thumb-initial">{{item.service_name}}</text>
          </view>
          <view class="featured-body">
            <view class="featured-meta">
              <view class="stars stars--sm">
                <text class="stars-bg">★★★★★</text>
                <text class="stars-fg" style="width:{{item.rating / 5 * 100}}%">★★★★★</text>
              </view>
              <text class="featured-svc" wx:if="{{item.service_name}}">{{item.service_name}}</text>
            </view>
            <text class="featured-quote">{{item.content}}</text>
            <text class="featured-from">— {{item.displayNickname}}</text>
          </view>
        </view>
      </view>

      <!-- REVW-10/D-04: 大家这样说 — 高频标签聚合（口碑转化 · 按热度分级） -->
      <view class="tag-cloud" wx:if="{{reviewStats.topTags && reviewStats.topTags.length}}">
        <view class="tag-cloud-head">
          <text class="tag-cloud-quote">❝</text>
          <text class="tag-cloud-title">大家这样说</text>
        </view>
        <view class="tag-cloud-list">
          <view class="cloud-chip cloud-chip--{{item.tier}}" wx:for="{{reviewStats.topTags}}" wx:key="key">
            <text class="cloud-chip-label">{{item.label}}</text>
            <text class="cloud-chip-count" wx:if="{{item.tier === 'hot'}}"> {{item.count}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- v2.3-r2: 预约 CTA — 主次分明，预约 dominant -->
    <view class="cta-panel">
      <view class="cta-stack">
        <button class="cta-book" bindtap="goToBooking">
          <text>立即预约化妆</text>
        </button>
        <button class="cta-contact" open-type="contact">
          <text>微信联系（先问问）</text>
        </button>
      </view>
    </view>
  </block>

  <view class="error-wrap" wx:if="{{!loading && error}}">
    <text class="error-text">{{error}}</text>
    <view class="error-retry tappable" bindtap="loadProfile">重试</view>
  </view>
</view>
