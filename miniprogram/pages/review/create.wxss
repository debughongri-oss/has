.page-review {
  min-height: 100vh;
  background-color: var(--bg);
  padding: 24rpx var(--page-pad) calc(48rpx + env(safe-area-inset-bottom));
}

/* ===== 卡片 ===== */
.card {
  background-color: var(--bg-elevated);
  border-radius: 26rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 16rpx;
}

.card-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.card-meta {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* ===== 评价对象 ===== */
.summary-eyebrow {
  display: inline-block;
  font-size: 20rpx;
  color: var(--accent);
  background-color: var(--accent-soft);
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  letter-spacing: 1rpx;
}

.summary-svc {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-top: 16rpx;
  letter-spacing: -0.5rpx;
}

.summary-time {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

/* ===== 评分 ===== */
.rate-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 28rpx 36rpx;
}

.rate-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.rate-stars {
  margin: 28rpx 0 20rpx;
}

.rate-input {
  display: flex;
  gap: 18rpx;
}

.rate-star {
  font-size: 72rpx;
  line-height: 1;
  color: rgba(0, 0, 0, 0.14);
}

.rate-star--on {
  color: var(--gold);
}

.rate-feedback {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.rate-feedback--on {
  color: #B0883F;
  font-weight: 700;
}

/* ===== 文字评价 ===== */
.ta {
  width: 100%;
  min-height: 200rpx;
  font-size: var(--fs-sm);
  line-height: 1.7;
  color: var(--text-primary);
  padding: 0;
}

.ph {
  color: var(--text-tertiary);
}

/* ===== 提交 ===== */
.submit-btn {
  margin-top: 32rpx;
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--accent-dark);
  color: #FFFFFF;
  border-radius: 24rpx;
  font-size: var(--fs-base);
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none;
  padding: 0;
  line-height: 1;
  box-shadow: 0 10rpx 24rpx rgba(232, 85, 117, 0.34);
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.45;
}
