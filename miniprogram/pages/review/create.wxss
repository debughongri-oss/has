.page-review {
  min-height: 100vh;
  background-color: var(--bg);
  /* 留出固定提交条的高度 + 安全区 */
  padding: 24rpx var(--page-pad) calc(180rpx + env(safe-area-inset-bottom));
}

/* ===== 卡片 ===== */
.card {
  background-color: var(--bg-elevated);
  border-radius: 26rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 16rpx;
}

.card-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.card-meta {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* ===== 评价对象 ===== */
.summary-eyebrow {
  display: inline-block;
  font-size: 20rpx;
  color: var(--accent);
  background-color: var(--accent-soft);
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  letter-spacing: 1rpx;
}

.summary-svc {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-top: 16rpx;
  letter-spacing: -0.5rpx;
}

.summary-time {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

/* ===== 评分 hero（美妆品牌淡腮红渐变） ===== */
.rate-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 44rpx 28rpx 40rpx;
  background-image: radial-gradient(circle at 50% 22%, var(--accent-light), var(--bg-elevated) 70%);
}

.rate-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.rate-stars {
  margin: 30rpx 0 22rpx;
}

.rate-input {
  display: flex;
  gap: 22rpx;
}

.rate-star {
  font-size: 84rpx;
  line-height: 1;
  color: rgba(201, 169, 110, 0.24);
}

.rate-star--on {
  color: var(--gold);
  text-shadow: 0 4rpx 14rpx rgba(201, 169, 110, 0.4);
}

.rate-feedback {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.rate-feedback--on {
  color: #B0883F;
  font-weight: 700;
}

/* ===== 文字评价 ===== */
.ta {
  width: 100%;
  min-height: 200rpx;
  font-size: var(--fs-sm);
  line-height: 1.7;
  color: var(--text-primary);
  padding: 0;
}

.ph {
  color: var(--text-tertiary);
}

/* ===== 标签 chip ===== */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-chip {
  padding: 14rpx 30rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--accent-medium);
  font-size: 26rpx;
  color: var(--text-secondary);
  background-color: var(--bg-elevated);
  line-height: 1.3;
  transition: all 0.18s ease;
}

.tag-chip--on {
  background-color: var(--accent);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(255, 111, 139, 0.32);
}

/* ===== 图片网格 ===== */
.img-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.img-cell {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: var(--bg);
}

.img-cell image {
  width: 100%;
  height: 100%;
  display: block;
}

.img-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.55);
  color: #FFFFFF;
  font-size: 26rpx;
  line-height: 36rpx;
  text-align: center;
}

.img-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed var(--gold);
  background-color: var(--gold-bg);
}

.img-add-plus {
  font-size: 56rpx;
  color: var(--gold);
  line-height: 1;
  font-weight: 300;
}

.img-add-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

/* ===== 匿名评价 + 自定义品牌开关 ===== */
.anon-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.anon-text {
  display: flex;
  flex-direction: column;
  flex: 1;
  padding-right: 24rpx;
}

.anon-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.anon-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

.toggle {
  width: 88rpx;
  height: 50rpx;
  border-radius: 999rpx;
  background-color: var(--fill-primary);
  position: relative;
  transition: background-color 0.2s ease;
  flex-shrink: 0;
}

.toggle--on {
  background-color: var(--gold);
}

.toggle-knob {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background-color: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.18);
  transition: transform 0.2s ease;
}

.toggle--on .toggle-knob {
  transform: translateX(38rpx);
}

/* ===== 固定底部提交条 ===== */
.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx var(--page-pad) calc(18rpx + env(safe-area-inset-bottom));
  background-color: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(12rpx);
  border-top: 1rpx solid var(--separator);
  z-index: 50;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #FF6F8B 0%, #E85575 100%);
  color: #FFFFFF;
  border-radius: 24rpx;
  font-size: var(--fs-base);
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none;
  padding: 0;
  line-height: 1;
  box-shadow: 0 10rpx 24rpx rgba(232, 85, 117, 0.34);
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.45;
  box-shadow: none;
}
