.page-review-create {
  min-height: 100vh;
  background-color: var(--bg);
  padding: 32rpx var(--page-pad);
}

.booking-summary {
  background-color: var(--bg-elevated);
  border-radius: var(--radius-md);
  padding: 28rpx var(--page-pad);
  margin-bottom: 32rpx;
}

.summary-svc {
  display: block;
  font-size: var(--fs-sm);
  font-weight: 600;
  color: var(--text-primary);
}

.summary-time {
  display: block;
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.form-section {
  background-color: var(--bg-elevated);
  border-radius: var(--radius-md);
  padding: 28rpx var(--page-pad);
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: var(--fs-sm);
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.review-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: var(--fs-sm);
  color: var(--text-primary);
  line-height: 1.7;
  padding: 0;
  background: transparent;
}

.char-count {
  display: block;
  text-align: right;
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
  margin-top: 12rpx;
}

.submit-btn {
  margin-top: 40rpx;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--accent);
  color: #FDFBF8;
  border-radius: var(--radius-md);
  font-size: var(--fs-sm);
  font-weight: 500;
  border: none;
  padding: 0;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.4;
  background-color: var(--accent);
  color: #FDFBF8;
}
