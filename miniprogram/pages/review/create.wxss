.page-review {
  min-height: 100vh;
  background-color: var(--bg);
  padding: 24rpx var(--page-pad) calc(48rpx + env(safe-area-inset-bottom));
}

/* ===== 卡片 ===== */
.card {
  background-color: var(--bg-elevated);
  border-radius: 26rpx;
  padding: 28rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 16rpx;
}

.card-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.card-meta {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

/* ===== 评价对象 ===== */
.summary-eyebrow {
  display: inline-block;
  font-size: 20rpx;
  color: var(--accent);
  background-color: var(--accent-soft);
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  letter-spacing: 1rpx;
}

.summary-svc {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-top: 16rpx;
  letter-spacing: -0.5rpx;
}

.summary-time {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 10rpx;
}

/* ===== 评分 ===== */
.rate-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 28rpx 36rpx;
}

.rate-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.rate-stars {
  margin: 28rpx 0 20rpx;
}

.rate-input {
  display: flex;
  gap: 18rpx;
}

.rate-star {
  font-size: 72rpx;
  line-height: 1;
  color: rgba(0, 0, 0, 0.14);
}

.rate-star--on {
  color: var(--gold);
}

.rate-feedback {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.rate-feedback--on {
  color: #B0883F;
  font-weight: 700;
}

/* ===== 文字评价 ===== */
.ta {
  width: 100%;
  min-height: 200rpx;
  font-size: var(--fs-sm);
  line-height: 1.7;
  color: var(--text-primary);
  padding: 0;
}

.ph {
  color: var(--text-tertiary);
}

/* ===== REVW-10: 标签 chip ===== */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-chip {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  border: 2rpx solid var(--accent-medium);
  font-size: 26rpx;
  color: var(--text-secondary);
  background-color: var(--bg-elevated);
  line-height: 1.3;
  transition: all 0.18s ease;
}

.tag-chip--on {
  background-color: var(--accent);
  color: #FFFFFF;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(255, 111, 139, 0.32);
}

/* ===== REVW-11: 图片网格 ===== */
.img-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.img-cell {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: var(--bg);
}

.img-cell image {
  width: 100%;
  height: 100%;
  display: block;
}

.img-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.55);
  color: #FFFFFF;
  font-size: 26rpx;
  line-height: 36rpx;
  text-align: center;
}

.img-add {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed var(--accent-medium);
  background-color: var(--accent-soft);
}

.img-add-plus {
  font-size: 56rpx;
  color: var(--accent);
  line-height: 1;
  font-weight: 300;
}

.img-add-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

/* ===== REVW-12: 匿名评价 ===== */
.anon-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.anon-text {
  display: flex;
  flex-direction: column;
  flex: 1;
  padding-right: 24rpx;
}

.anon-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.anon-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

/* ===== 提交 ===== */
.submit-btn {
  margin-top: 32rpx;
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--accent-dark);
  color: #FFFFFF;
  border-radius: 24rpx;
  font-size: var(--fs-base);
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none;
  padding: 0;
  line-height: 1;
  box-shadow: 0 10rpx 24rpx rgba(232, 85, 117, 0.34);
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.45;
}
