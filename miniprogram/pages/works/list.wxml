<view class="page-works">
  <view class="works-header">
    <text class="works-title">作品集</text>
    <text class="works-subtitle">真实客片 · 持续更新</text>
  </view>

  <view class="cat-bar">
    <scroll-view scroll-x enhanced show-scrollbar="{{false}}">
      <view class="cat-track">
        <view
          class="cat-item tappable {{currentCategory === item.key ? 'cat-item--active' : ''}}"
          wx:for="{{categories}}"
          wx:key="key"
          bindtap="onCategoryChange"
          data-key="{{item.key}}"
        >
          <text class="cat-label">{{item.label}}</text>
          <view class="cat-indicator"></view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="loading-container" wx:if="{{loading && !works.length}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{works.length}}">
    <view class="featured-head" wx:if="{{heroWork}}">
      <view class="featured-mark"></view>
      <text class="featured-title">本月精选</text>
      <text class="featured-count">{{works.length}} 件</text>
    </view>

    <view
      class="hero tappable"
      wx:if="{{heroWork}}"
      bindtap="goToDetail"
      data-id="{{heroWork._id}}"
    >
      <image class="hero-img" src="{{heroWork.images[0]}}" mode="aspectFill" lazy-load />
      <view class="hero-badge" wx:if="{{heroWork.hasBeforeAfter}}">前后对比</view>
      <view class="hero-caption">
        <text class="hero-title text-ellipsis">{{heroWork.title}}</text>
        <text class="hero-cat" wx:if="{{heroWork.categoryLabel}}">{{heroWork.categoryLabel}}</text>
      </view>
    </view>

    <view class="gallery-head" wx:if="{{works.length > 1}}">
      <text class="gallery-label">{{galleryTitle}}</text>
      <view class="gallery-rule"></view>
    </view>

    <view class="gallery" wx:if="{{works.length > 1}}">
      <view class="gallery-col">
        <view
          class="work-item tappable"
          wx:for="{{leftColumn}}"
          wx:key="_id"
          bindtap="goToDetail"
          data-id="{{item._id}}"
        >
          <view class="work-media">
            <image class="work-img" src="{{item.images[0]}}" mode="aspectFill" lazy-load />
          </view>
          <view class="work-meta">
            <text class="work-title text-ellipsis">{{item.title}}</text>
            <view class="work-foot">
              <text class="work-cat" wx:if="{{item.categoryLabel}}">{{item.categoryLabel}}</text>
              <text class="work-compare" wx:if="{{item.hasBeforeAfter}}">前后对比 ›</text>
            </view>
          </view>
        </view>
      </view>

      <view class="gallery-col">
        <view
          class="work-item tappable"
          wx:for="{{rightColumn}}"
          wx:key="_id"
          bindtap="goToDetail"
          data-id="{{item._id}}"
        >
          <view class="work-media">
            <image class="work-img" src="{{item.images[0]}}" mode="aspectFill" lazy-load />
          </view>
          <view class="work-meta">
            <text class="work-title text-ellipsis">{{item.title}}</text>
            <view class="work-foot">
              <text class="work-cat" wx:if="{{item.categoryLabel}}">{{item.categoryLabel}}</text>
              <text class="work-compare" wx:if="{{item.hasBeforeAfter}}">前后对比 ›</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="load-more" wx:if="{{hasMore}}">
      <t-loading wx:if="{{loadingMore}}" theme="circular" size="40rpx" />
      <view wx:else class="load-more-btn tappable" bindtap="loadMore">展开更多</view>
    </view>
    <view class="list-end" wx:else>
      <text class="list-end-text">已展示全部作品</text>
    </view>

    <view class="booking-cta">
      <text class="booking-copy">看中喜欢的妆容？</text>
      <button class="booking-action" bindtap="goToBooking">去预约</button>
    </view>
  </block>

  <view class="empty-container" wx:if="{{!loading && !works.length}}">
    <view class="empty">
      <view class="empty-icon"></view>
      <text class="empty-text">暂无作品</text>
    </view>
  </view>
</view>
