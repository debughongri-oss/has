.page-works {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ===== 分类筛选 ===== */
.cat-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: var(--bg);
  padding: 20rpx 0 16rpx;
}

.cat-track {
  display: inline-flex;
  padding: 0 var(--page-pad);
  gap: 14rpx;
}

.cat-chip {
  flex-shrink: 0;
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  white-space: nowrap;
  padding: 14rpx 32rpx;
  border-radius: 999rpx;
  background-color: var(--bg-elevated);
  border: 1rpx solid var(--separator-opaque);
}

.cat-chip--active {
  background-color: var(--accent);
  color: #FFFFFF;
  border-color: var(--accent);
  font-weight: 600;
}

/* ===== 精选大图 ===== */
.hero {
  position: relative;
  margin: 8rpx var(--page-pad) 0;
  height: 560rpx;
  border-radius: 28rpx;
  overflow: hidden;
  background-color: var(--accent-light);
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.08);
}

.hero-img {
  width: 100%;
  height: 100%;
  display: block;
}

.hero-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  background-color: rgba(0, 0, 0, 0.45);
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}

.hero-scrim {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 56rpx 28rpx 28rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0));
}

.hero-cat {
  display: inline-block;
  font-size: 20rpx;
  color: #FFFFFF;
  background-color: rgba(255, 255, 255, 0.24);
  padding: 5rpx 18rpx;
  border-radius: 999rpx;
  margin-bottom: 14rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
}

/* ===== 章节头 ===== */
.gallery-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 44rpx var(--page-pad) 24rpx;
}

.gallery-label {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
}

.gallery-count {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
}

/* ===== 瀑布流 ===== */
.masonry {
  display: flex;
  gap: 16rpx;
  padding: 0 var(--page-pad);
}

.masonry-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card {
  border-radius: 24rpx;
  overflow: hidden;
  background-color: var(--bg-elevated);
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.card-media {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
}

.card:nth-child(3n+1) .card-media {
  height: 440rpx;
}

.card:nth-child(3n+3) .card-media {
  height: 320rpx;
}

.card-img {
  width: 100%;
  height: 100%;
  display: block;
}

.card-badge {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  background-color: rgba(0, 0, 0, 0.5);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.card-meta {
  padding: 16rpx 18rpx 20rpx;
}

.card-title {
  display: block;
  font-size: var(--fs-sm);
  font-weight: 600;
  color: var(--text-primary);
}

.card-cat {
  display: inline-block;
  font-size: 20rpx;
  color: var(--accent);
  background-color: var(--accent-soft);
  padding: 3rpx 14rpx;
  border-radius: 999rpx;
  margin-top: 10rpx;
}

/* ===== 加载更多 / 到底 ===== */
.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 44rpx var(--page-pad) 16rpx;
}

.load-more-btn {
  padding: 16rpx 48rpx;
  background-color: var(--bg-elevated);
  border: 1rpx solid var(--separator-opaque);
  border-radius: 999rpx;
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  font-weight: 500;
}

.list-end {
  display: flex;
  justify-content: center;
  padding: 48rpx var(--page-pad) 24rpx;
}

.list-end-text {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
  letter-spacing: 1rpx;
}
