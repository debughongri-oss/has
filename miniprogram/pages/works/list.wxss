.page-works {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ===== Category chip bar ===== */
.cat-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: var(--bg);
  padding: 20rpx 0 24rpx;
}

.cat-track {
  display: inline-flex;
  padding: 0 var(--page-pad);
  gap: 14rpx;
}

.cat-chip {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background-color: transparent;
  transition: background-color 0.2s ease;
}

.cat-chip-text {
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  white-space: nowrap;
  letter-spacing: 1rpx;
  transition: color 0.2s ease;
}

.cat-chip--active {
  background-color: var(--accent-soft);
}

.cat-chip--active .cat-chip-text {
  color: var(--accent);
  font-weight: 500;
}

/* ===== Hero feature card ===== */
.hero {
  margin: 8rpx var(--page-pad) 0;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background-color: var(--bg-elevated);
}

.hero-media {
  position: relative;
  width: 100%;
  height: 560rpx;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
  display: block;
}

.hero-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  padding: 6rpx 18rpx;
  background-color: rgba(31, 27, 24, 0.45);
  backdrop-filter: blur(12px);
  border-radius: 999rpx;
}

.hero-badge-text {
  font-size: 20rpx;
  color: #F5F5F5;
  letter-spacing: 1rpx;
}

.hero-meta {
  padding: 24rpx 28rpx 28rpx;
}

.hero-eyebrow {
  display: block;
  font-size: var(--fs-xs);
  color: var(--accent);
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}

.hero-title {
  display: block;
  font-size: var(--fs-lg);
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.3;
}

/* ===== Gallery section head ===== */
.gallery-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 48rpx var(--page-pad) 28rpx;
}

.gallery-label {
  font-size: var(--fs-base);
  font-weight: 600;
  color: var(--text-primary);
}

.gallery-count {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
  letter-spacing: 1rpx;
}

/* ===== Masonry ===== */
.masonry {
  display: flex;
  padding: 0 var(--page-pad);
  gap: 14rpx;
}

.masonry-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  min-width: 0;
}

/* ===== Cards ===== */
.card {
  border-radius: var(--radius-md);
  overflow: hidden;
  background-color: var(--bg-elevated);
}

.card-media {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
}

.card:nth-child(3n+1) .card-media {
  height: 440rpx;
}

.card:nth-child(3n+3) .card-media {
  height: 320rpx;
}

.card-img {
  width: 100%;
  height: 100%;
  display: block;
}

.card-badge {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  padding: 4rpx 14rpx;
  background-color: rgba(31, 27, 24, 0.5);
  backdrop-filter: blur(10px);
  border-radius: 999rpx;
}

.card-badge-text {
  font-size: 20rpx;
  color: #F5F5F5;
  letter-spacing: 1rpx;
}

.card-meta {
  padding: 14rpx 16rpx 18rpx;
}

.card-eyebrow {
  display: block;
  font-size: var(--fs-xs);
  color: var(--accent);
  letter-spacing: 1rpx;
  margin-bottom: 4rpx;
}

.card-title {
  display: block;
  font-size: var(--fs-sm);
  font-weight: 500;
  color: var(--text-primary);
}

/* ===== Load more + list end ===== */
.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 48rpx var(--page-pad) 16rpx;
}

.load-more-trigger {
  padding: 12rpx 36rpx;
}

.load-more-hint {
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  letter-spacing: 1rpx;
}

.list-end {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx var(--page-pad) 32rpx;
  gap: 20rpx;
}

.list-end-rule {
  width: 48rpx;
  height: 2rpx;
  background-color: var(--separator-opaque);
}

.list-end-text {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
  letter-spacing: 2rpx;
}
