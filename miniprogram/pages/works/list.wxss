.page-works {
  min-height: 100vh;
  box-sizing: border-box;
  background-color: #FBFAF8;
  padding-bottom: calc(176rpx + env(safe-area-inset-bottom));
}

/* ===== 页面标题 ===== */
.works-header {
  padding: 24rpx var(--page-pad) 20rpx;
}

.works-title {
  display: block;
  font-size: 60rpx;
  line-height: 1.12;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.works-subtitle {
  display: block;
  margin-top: 14rpx;
  color: var(--text-tertiary);
  font-size: 24rpx;
  line-height: 1.4;
  letter-spacing: 1rpx;
}

/* ===== 分类筛选 ===== */
.cat-bar {
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: rgba(251, 250, 248, 0.96);
  padding: 8rpx 0 18rpx;
}

.cat-track {
  display: inline-flex;
  min-width: 100%;
  box-sizing: border-box;
  padding: 0 var(--page-pad);
  gap: 46rpx;
}

.cat-item {
  position: relative;
  flex-shrink: 0;
  padding: 18rpx 0 16rpx;
  color: var(--text-secondary);
}

.cat-label {
  font-size: 28rpx;
  line-height: 1;
  white-space: nowrap;
}

.cat-indicator {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 0;
  height: 5rpx;
  border-radius: 999rpx;
  background-color: var(--accent-dark);
  transform: translateX(-50%);
  transition: width 0.18s ease;
}

.cat-item--active {
  color: var(--accent-dark);
  font-weight: 700;
}

.cat-item--active .cat-indicator {
  width: 52rpx;
}

/* ===== 本月精选 ===== */
.featured-head {
  display: flex;
  align-items: center;
  padding: 34rpx var(--page-pad) 22rpx;
}

.featured-mark {
  width: 14rpx;
  height: 14rpx;
  margin-right: 16rpx;
  background-color: var(--gold);
  transform: rotate(45deg);
}

.featured-title {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--text-primary);
}

.featured-count {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.hero {
  position: relative;
  height: 460rpx;
  margin: 0 var(--page-pad);
  overflow: hidden;
  border-radius: 18rpx;
  background-color: #EFE8E4;
}

.hero-img {
  display: block;
  width: 100%;
  height: 100%;
}

.hero-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  color: #FFFFFF;
  background-color: rgba(23, 21, 26, 0.62);
  font-size: 20rpx;
  line-height: 1.2;
}

.hero-caption {
  position: absolute;
  left: 22rpx;
  bottom: 22rpx;
  max-width: 70%;
  padding: 18rpx 22rpx;
  border-radius: 10rpx;
  color: #FFFFFF;
  background-color: rgba(23, 21, 26, 0.58);
}

.hero-title {
  display: block;
  color: #FFFFFF;
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 700;
}

.hero-cat {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 22rpx;
  line-height: 1.2;
}

/* ===== 双列作品画廊 ===== */
.gallery-head {
  display: flex;
  align-items: center;
  padding: 42rpx var(--page-pad) 20rpx;
}

.gallery-label {
  flex-shrink: 0;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.gallery-rule {
  flex: 1;
  height: 1rpx;
  margin-left: 22rpx;
  background-color: var(--separator-opaque);
}

.gallery {
  display: flex;
  gap: 14rpx;
  padding: 0 var(--page-pad);
}

.gallery-col {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  gap: 18rpx;
}

.work-item {
  overflow: hidden;
  border-radius: 14rpx;
  background-color: #FFFFFF;
  box-shadow: 0 3rpx 14rpx rgba(56, 41, 35, 0.05);
}

.work-media {
  width: 100%;
  height: 310rpx;
  overflow: hidden;
  background-color: #EFE8E4;
}

.work-item:nth-child(3n + 1) .work-media {
  height: 350rpx;
}

.work-item:nth-child(3n + 3) .work-media {
  height: 280rpx;
}

.work-img {
  display: block;
  width: 100%;
  height: 100%;
}

.work-meta {
  padding: 16rpx 18rpx 18rpx;
}

.work-title {
  display: block;
  color: var(--text-primary);
  font-size: 27rpx;
  line-height: 1.3;
  font-weight: 600;
}

.work-foot {
  display: flex;
  align-items: center;
  min-height: 30rpx;
  margin-top: 10rpx;
}

.work-cat {
  color: #A78247;
  font-size: 21rpx;
  line-height: 1.2;
}

.work-compare {
  margin-left: auto;
  color: var(--text-secondary);
  font-size: 20rpx;
  line-height: 1.2;
  white-space: nowrap;
}

/* ===== 加载状态 ===== */
.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 46rpx var(--page-pad) 12rpx;
}

.load-more-btn {
  padding: 16rpx 48rpx;
  border: 1rpx solid var(--separator-opaque);
  border-radius: 999rpx;
  background-color: #FFFFFF;
  color: var(--text-secondary);
  font-size: var(--fs-xs);
  font-weight: 500;
}

.list-end {
  display: flex;
  justify-content: center;
  padding: 44rpx var(--page-pad) 16rpx;
}

.list-end-text {
  color: var(--text-tertiary);
  font-size: var(--fs-xs);
  letter-spacing: 1rpx;
}

/* ===== 预约入口 ===== */
.booking-cta {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  height: 112rpx;
  margin: 0;
  padding: 14rpx var(--page-pad);
  border: 1rpx solid rgba(232, 85, 117, 0.12);
  border-bottom: none;
  border-radius: 18rpx 18rpx 0 0;
  background-color: #FFF7F7;
  box-shadow: 0 -6rpx 24rpx rgba(67, 43, 45, 0.10);
}

.booking-copy {
  flex: 1;
  min-width: 0;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.3;
}

.booking-action {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 176rpx;
  min-width: 176rpx;
  max-width: 176rpx;
  height: 76rpx;
  margin-left: auto;
  padding: 0;
  border: none;
  border-radius: 999rpx;
  background-color: var(--accent-dark);
  color: #FFFFFF;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1;
}

.booking-action::after {
  border: none;
}
