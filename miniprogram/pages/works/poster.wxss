.poster-page {
  min-height: 100vh;
  background-color: rgba(0, 0, 0, 0.7);
  display: flex;
  flex-direction: column;
}

/* 自定义导航栏 */
.poster-navbar {
  background-color: transparent;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 var(--page-pad);
}

.navbar-back {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.navbar-back-icon {
  width: 36rpx;
  height: 36rpx;
  background-image: var(--icon-close);
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.navbar-title {
  font-size: var(--fs-base);
  font-weight: 500;
  color: #F5F5F5;
}

.navbar-placeholder {
  width: 68rpx;
}

/* 加载状态 */
.poster-loading {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 错误状态 */
.poster-error {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 32rpx;
}

.poster-error-text {
  font-size: var(--fs-base);
  color: rgba(255, 255, 255, 0.6);
}

.poster-retry-btn {
  width: 280rpx;
  height: 80rpx;
  font-size: var(--fs-sm);
}

/* 离屏 Canvas per D-22 */
.poster-canvas {
  position: fixed;
  left: -9999px;
  width: 750px;
  height: 1060px;
}

/* 海报预览区域 */
.poster-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 var(--page-pad);
}

.poster-preview {
  width: 85%;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.3);
}

.poster-image {
  width: 100%;
  display: block;
}

/* 底部操作栏 */
.poster-actions {
  width: 100%;
  padding: 36rpx var(--page-pad) 60rpx;
}

.poster-save-btn {
  width: 100%;
  height: 100rpx;
  font-size: var(--fs-base);
}

.poster-save-btn[disabled] {
  opacity: 0.5;
  background-color: var(--accent-dark);
  color: #FFFFFF;
}
