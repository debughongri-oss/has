<view class="page-services">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading && serviceGroups.length}}">
    <view class="head">
      <text class="head-title">服务菜单</text>
      <text class="head-sub">选择心仪的妆容，点击即可在线预约 · 共 {{totalCount}} 项</text>
    </view>

    <block wx:for="{{serviceGroups}}" wx:key="key" wx:for-item="group">
      <view class="sec-head">
        <view class="sec-dot sec-dot--{{group.tone}}"></view>
        <text class="sec-label">{{group.label}}</text>
        <text class="sec-count">{{group.services.length}} 项</text>
      </view>

      <view class="cards">
        <view
          class="card tappable"
          wx:for="{{group.services}}"
          wx:key="_id"
          wx:for-item="service"
          bindtap="goToBook"
          data-id="{{service._id}}"
        >
          <view class="card-top">
            <view class="svc-ic svc-ic--{{service.tone}}">{{service.icon}}</view>
            <view class="card-body">
              <text class="card-name">{{service.name}}</text>
              <text class="card-desc text-ellipsis-2" wx:if="{{service.description}}">{{service.description}}</text>
            </view>
          </view>
          <view class="card-foot">
            <text class="dur" wx:if="{{service.duration}}">{{service.duration}}分钟</text>
            <view class="foot-r">
              <view class="price">
                <text class="price-sym">¥</text>
                <text class="price-num">{{service.price}}</text>
              </view>
              <view class="book">
                <text>预约</text>
                <view class="book-arr"></view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
  </block>

  <view class="empty-container" wx:if="{{!loading && !serviceGroups.length}}">
    <view class="empty">
      <view class="empty-icon"></view>
      <text class="empty-text">暂无服务项目</text>
    </view>
  </view>
</view>
