.page-services {
  min-height: 100vh;
  background-color: var(--bg-elevated);
  padding-bottom: env(safe-area-inset-bottom);
}

.header {
  padding: 48rpx var(--page-pad) 0;
}

.header-title {
  display: block;
  font-size: var(--fs-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.header-sub {
  display: block;
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.list {
  padding: 36rpx var(--page-pad) 0;
}

.svc {
  padding: 32rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.svc:last-child {
  border-bottom: none;
}

.svc-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.svc-left {
  flex: 1;
  min-width: 0;
}

.svc-name {
  display: block;
  font-size: var(--fs-base);
  font-weight: 600;
  color: var(--text-primary);
}

.svc-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
  font-size: var(--fs-xs);
  color: var(--text-secondary);
}

.svc-sep {
  color: var(--text-tertiary);
}

.svc-price-wrap {
  flex-shrink: 0;
  text-align: right;
  margin-left: 24rpx;
  display: flex;
  align-items: baseline;
  gap: 2rpx;
}

.svc-price {
  font-size: var(--fs-base);
  font-weight: 600;
  color: var(--accent);
}

.svc-price-unit {
  font-size: var(--fs-xs);
  color: var(--accent);
}

.svc-desc {
  display: block;
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.8;
  margin-top: 20rpx;
}

.bottom-cta {
  padding: 48rpx var(--page-pad) 56rpx;
}

.cta-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: var(--accent);
  color: #FDFBF8;
  border-radius: var(--radius-md);
  font-size: var(--fs-sm);
  font-weight: 500;
  border: none;
  transition: opacity 0.15s ease, transform 0.15s ease;
}

.cta-btn::after {
  border: none;
}

.cta-btn:active {
  opacity: 0.8;
  transform: scale(0.97);
}
