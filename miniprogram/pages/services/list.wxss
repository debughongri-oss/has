.page-services {
  min-height: 100vh;
  background-color: var(--bg);
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* ===== 头部 ===== */
.head {
  padding: 40rpx var(--page-pad) 12rpx;
}

.head-title {
  display: block;
  font-size: 46rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -1rpx;
}

.head-sub {
  display: block;
  margin-top: 12rpx;
  font-size: var(--fs-sm);
  color: var(--text-secondary);
}

/* ===== 分类区 ===== */
.sec-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 40rpx var(--page-pad) 20rpx;
}

.sec-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.sec-dot--rose { background-color: #C4727F; }
.sec-dot--purple { background-color: #8B6FA0; }
.sec-dot--gold { background-color: #B0883F; }
.sec-dot--green { background-color: #5A9E6F; }
.sec-dot--blue { background-color: #5A7FA0; }

.sec-label {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -0.5rpx;
}

.sec-count {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
}

/* ===== 服务卡片 ===== */
.cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 0 var(--page-pad);
}

.card {
  background-color: var(--bg-elevated);
  border-radius: 26rpx;
  padding: 26rpx 26rpx 22rpx;
  box-shadow: 0 8rpx 22rpx rgba(0, 0, 0, 0.05);
}

.card-top {
  display: flex;
  gap: 20rpx;
}

.svc-ic {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  flex-shrink: 0;
  overflow: hidden;
}

.svc-ic-cover {
  width: 100%;
  height: 100%;
  display: block;
}

.svc-ic--rose { background-color: rgba(196, 114, 127, 0.13); color: #C4727F; }
.svc-ic--purple { background-color: rgba(139, 111, 160, 0.13); color: #8B6FA0; }
.svc-ic--gold { background-color: rgba(201, 169, 110, 0.16); color: #B0883F; }
.svc-ic--green { background-color: rgba(90, 158, 111, 0.13); color: #5A9E6F; }
.svc-ic--blue { background-color: rgba(90, 127, 160, 0.13); color: #5A7FA0; }

.card-body {
  flex: 1;
  min-width: 0;
}

.card-name {
  display: block;
  font-size: var(--fs-base);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.35;
}

.card-desc {
  display: block;
  margin-top: 8rpx;
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  line-height: 1.65;
}

.card-foot {
  display: flex;
  align-items: center;
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--separator);
}

.dur {
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  background-color: var(--fill-primary);
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
}

.foot-r {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.price {
  display: flex;
  align-items: baseline;
  color: var(--accent);
}

.price-sym {
  font-size: var(--fs-xs);
  font-weight: 700;
}

.price-num {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
}

.book {
  display: flex;
  align-items: center;
  gap: 4rpx;
  height: 64rpx;
  padding: 0 30rpx;
  background-color: var(--accent);
  color: #FFFFFF;
  border-radius: 999rpx;
  font-size: var(--fs-sm);
  font-weight: 700;
  box-shadow: 0 6rpx 16rpx rgba(255, 111, 139, 0.32);
}

.book-arr {
  width: 18rpx;
  height: 18rpx;
  border-top: 3rpx solid #FFFFFF;
  border-right: 3rpx solid #FFFFFF;
  transform: rotate(45deg);
  margin-left: 2rpx;
}
