@import "../../styles/booking-form.wxss";

.page-booking {
  min-height: 100vh;
  background-color: var(--bg);
  padding: 20rpx 0 calc(190rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ===== 服务项目 ===== */
.service-list {
  position: relative;
  z-index: 1;
  margin-top: 28rpx;
  padding-left: 64rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.service-row {
  height: 174rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  border: 2rpx solid var(--separator-opaque);
  background-color: #FFFFFF;
  box-sizing: border-box;
}

.service-row--on {
  border-color: var(--accent);
  background-color: rgba(255, 111, 139, 0.055);
}

.service-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background-color: var(--accent-soft);
}

.service-icon {
  width: 46rpx;
  height: 46rpx;
}

/* 有封面时：图片铺满整个色块（aspectFill 裁剪），不再露出色块底色 */
.service-icon-wrap--cover {
  background-color: transparent;
  overflow: hidden;
}

.service-icon-wrap--cover .service-icon {
  width: 100%;
  height: 100%;
}

.service-main {
  flex: 1;
  min-width: 0;
  height: 112rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.service-title-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.service-name {
  display: block;
  min-width: 0;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 30rpx;
  color: var(--text-primary);
  font-weight: 800;
}

.service-tag {
  max-width: 116rpx;
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  color: var(--accent);
  background-color: var(--accent-soft);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.service-desc {
  margin-top: 9rpx;
  font-size: 24rpx;
  line-height: 1.45;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.service-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 600;
  overflow: hidden;
  white-space: nowrap;
}

.service-check {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--separator-opaque);
}

.service-row--on .service-check {
  background-color: var(--accent);
  border-color: var(--accent);
}

.service-check image {
  width: 28rpx;
  height: 28rpx;
  filter: brightness(0) invert(1);
}

.empty-pad {
  padding: 48rpx 0 12rpx 64rpx;
}

/* ===== 提交栏 ===== */
.dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: grid;
  grid-template-columns: 24% 1rpx minmax(0, 1fr) 25%;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -10rpx 28rpx rgba(0, 0, 0, 0.08);
  box-sizing: border-box;
}

.dock-price-area {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.dock-price-wrap {
  min-width: 0;
  flex-shrink: 0;
  display: flex;
  align-items: baseline;
  color: var(--accent);
}

.dock-yen {
  font-size: 28rpx;
  font-weight: 700;
}

.dock-price {
  max-width: 104rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 800;
}

.dock-detail {
  flex-shrink: 0;
  padding: 6rpx 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-secondary);
  background-color: transparent;
  font-size: 22rpx;
  font-weight: 500;
}

.dock-detail--disabled {
  opacity: 0.45;
}

.dock-divider {
  width: 1rpx;
  height: 66rpx;
  flex-shrink: 0;
  background-color: var(--separator-opaque);
}

.dock-copy {
  flex: 1;
  min-width: 0;
}

.dock-when {
  display: block;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 700;
}

.dock-svc {
  display: block;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 5rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.dock-btn {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  background-color: var(--accent-dark);
  color: #FFFFFF;
  border-radius: 20rpx;
  font-size: 29rpx;
  font-weight: 800;
  white-space: nowrap;
  box-sizing: border-box;
  border: none;
  line-height: 1;
  box-shadow: 0 8rpx 20rpx rgba(232, 85, 117, 0.3);
}

.dock-btn::after {
  border: none;
}

.dock-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.dock-btn[disabled] {
  opacity: 0.42;
  box-shadow: none;
}

/* ===== 明细弹层 ===== */
.detail-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 200;
  display: flex;
  align-items: flex-end;
  background-color: rgba(0, 0, 0, 0.28);
  animation: detailMaskIn 240ms ease both;
}

.detail-mask--leave {
  animation: detailMaskOut 200ms ease both;
}

.detail-sheet {
  width: 100%;
  max-height: 78vh;
  overflow-y: auto;
  padding: 30rpx var(--page-pad) calc(34rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  border-radius: 30rpx 30rpx 0 0;
  box-sizing: border-box;
  animation: detailSheetIn 300ms cubic-bezier(0.22, 0.61, 0.36, 1) both;
}

.detail-sheet--leave {
  animation: detailSheetOut 220ms cubic-bezier(0.4, 0, 1, 1) both;
}

/* 明细弹层动画 */
@keyframes detailMaskIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes detailMaskOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

@keyframes detailSheetIn {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

@keyframes detailSheetOut {
  from { transform: translateY(0); }
  to { transform: translateY(100%); }
}

@media (prefers-reduced-motion: reduce) {
  .detail-mask,
  .detail-mask--leave,
  .detail-sheet,
  .detail-sheet--leave {
    animation: none;
  }
}

.detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 26rpx;
}

.detail-title {
  display: block;
  font-size: 36rpx;
  line-height: 1.2;
  color: var(--text-primary);
  font-weight: 800;
}

.detail-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 圆形 ✕ 关闭按钮 */
.detail-close {
  flex-shrink: 0;
  position: relative;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: var(--fill-primary);
}

.detail-close::before,
.detail-close::after {
  content: '';
  position: absolute;
  left: 50%;
  top: 50%;
  width: 22rpx;
  height: 2rpx;
  background-color: var(--text-secondary);
}

.detail-close::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.detail-close::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

/* 预约主卡：整卡取分类色调，左强调条 + 分类标签 */
.hero {
  position: relative;
  margin-bottom: 28rpx;
  padding: 28rpx 28rpx 26rpx 34rpx;
  background-color: var(--accent-light);
  border-radius: 24rpx;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background-color: var(--accent);
}

.hero--rose { background-color: var(--rose-bg); }
.hero--rose::before { background-color: var(--rose); }
.hero--purple { background-color: var(--purple-bg); }
.hero--purple::before { background-color: var(--purple); }
.hero--gold { background-color: var(--gold-bg); }
.hero--gold::before { background-color: var(--gold); }
.hero--green { background-color: var(--green-bg); }
.hero--green::before { background-color: var(--green); }
.hero--blue { background-color: var(--blue-bg); }
.hero--blue::before { background-color: var(--blue); }

.hero-top {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.hero-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.hero-name {
  flex: 1;
  min-width: 0;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
  color: var(--text-primary);
}

.hero-cat {
  flex-shrink: 0;
  padding: 5rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--accent);
  background-color: #FFFFFF;
}

.hero--rose .hero-cat { color: var(--rose); }
.hero--purple .hero-cat { color: var(--purple); }
.hero--gold .hero-cat { color: var(--gold); }
.hero--green .hero-cat { color: var(--green); }
.hero--blue .hero-cat { color: var(--blue); }

.hero-when {
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.hero-date {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.hero-dot {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.hero-time {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-primary);
}

.hero-mode {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  font-size: 25rpx;
  color: var(--text-secondary);
}

.hero-mode-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.hero-addr {
  flex: 1;
  min-width: 0;
  color: var(--text-tertiary);
  word-break: break-all;
}

/* 分组小节 */
.sect {
  margin-bottom: 24rpx;
}

.sect-title {
  display: block;
  margin-bottom: 14rpx;
  padding-left: 6rpx;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: var(--text-tertiary);
}

.kv-card {
  border: 1rpx solid var(--separator-opaque);
  border-radius: 20rpx;
  overflow: hidden;
}

.kv {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid var(--separator);
}

.kv:last-child {
  border-bottom: none;
}

.kv-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.kv-key {
  width: 132rpx;
  flex-shrink: 0;
  font-size: 25rpx;
  color: var(--text-tertiary);
}

.kv-val {
  flex: 1;
  min-width: 0;
  font-size: 27rpx;
  line-height: 1.4;
  color: var(--text-primary);
  text-align: right;
  word-break: break-all;
}

/* 价格合计 */
.total {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 8rpx;
  padding: 26rpx 8rpx 6rpx;
  border-top: 1rpx solid var(--separator);
}

.total-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.total-amount {
  font-size: 42rpx;
  font-weight: 800;
  color: var(--accent);
}

.total-yen {
  margin-right: 2rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: var(--accent);
}
