.page-booking {
  min-height: 100vh;
  background-color: var(--bg-elevated);
  padding-bottom: 220rpx;
}

.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx var(--page-pad) 20rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.step-num {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 50%;
  font-size: var(--fs-xs);
  font-weight: 600;
  color: var(--text-tertiary);
  background-color: var(--fill-primary);
}

.step--on .step-num {
  background-color: var(--accent);
  color: #FDFBF8;
}

.step--done .step-num {
  background-color: var(--accent);
  color: #FDFBF8;
}

.step-label {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
}

.step--on .step-label {
  color: var(--accent);
}

.step--done .step-label {
  color: var(--accent);
}

.step-line {
  flex: 1;
  height: 2rpx;
  background-color: var(--separator);
  margin: 0 16rpx;
  margin-bottom: 24rpx;
}

.step-line--done {
  background-color: var(--accent);
}

.form-block {
  padding: 36rpx var(--page-pad) 0;
}

.form-title {
  display: block;
  font-size: var(--fs-xs);
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
}

.svc-list {
  display: flex;
  flex-direction: column;
}

.svc-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--separator);
}

.svc-row:last-child {
  border-bottom: none;
}

.svc-row--on {
  background-color: var(--accent-soft);
  margin: 0 -32rpx;
  padding: 24rpx 32rpx;
  border-radius: var(--radius-md);
  border-bottom-color: transparent;
}

.svc-info {
  flex: 1;
  min-width: 0;
}

.svc-name {
  display: block;
  font-size: var(--fs-sm);
  font-weight: 500;
  color: var(--text-primary);
}

.svc-dur {
  display: block;
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.svc-price {
  flex-shrink: 0;
  font-size: var(--fs-sm);
  color: var(--accent);
  font-weight: 600;
  margin-right: 16rpx;
}

.svc-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: var(--accent);
  flex-shrink: 0;
  position: relative;
}

.svc-check::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 12rpx;
  height: 20rpx;
  border-bottom: 3rpx solid #FDFBF8;
  border-right: 3rpx solid #FDFBF8;
  transform: translate(-65%, -60%) rotate(45deg);
}

.empty-pad {
  padding: 64rpx 0;
}

.date-track {
  display: inline-flex;
  gap: 12rpx;
}

.date {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 92rpx;
  padding: 14rpx 0;
  border: 2rpx solid var(--separator);
  border-radius: var(--radius-md);
}

.date--on {
  border-color: var(--accent);
  background-color: var(--accent);
}

.date-wk {
  font-size: var(--fs-xs);
  color: var(--text-secondary);
}

.date-num {
  font-size: var(--fs-sm);
  font-weight: 600;
  color: var(--text-primary);
  margin: 4rpx 0;
}

.date-mo {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
}

.date--on .date-wk,
.date--on .date-num,
.date--on .date-mo {
  color: #FDFBF8;
}

.slot-load {
  display: flex;
  justify-content: center;
  padding: 48rpx;
}

.time-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.time {
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: var(--radius-sm);
  font-size: var(--fs-sm);
}

.time--off {
  background-color: var(--fill-secondary);
  color: var(--text-primary);
}

.time--on {
  background-color: var(--accent);
  color: #FDFBF8;
  font-weight: 500;
}

.time--no {
  background-color: var(--fill-tertiary);
  color: var(--text-tertiary);
  text-decoration: line-through;
}

.note {
  width: 100%;
  height: 160rpx;
  padding: 24rpx;
  background-color: var(--fill-secondary);
  border-radius: var(--radius-md);
  font-size: var(--fs-sm);
  box-sizing: border-box;
  line-height: 1.7;
  border: none;
  color: var(--text-primary);
}

.submit {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: var(--bg-elevated);
  border-top: 1rpx solid var(--separator);
  padding: 24rpx var(--page-pad);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.submit-summary {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.submit-service {
  color: var(--accent);
  font-weight: 500;
}

.submit-dot {
  color: var(--text-tertiary);
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: var(--accent);
  color: #FDFBF8;
  border-radius: var(--radius-md);
  font-size: var(--fs-sm);
  font-weight: 500;
  border: none;
  transition: opacity 0.15s ease, transform 0.15s ease;
}

.submit-btn::after {
  border: none;
}

.submit-btn:active {
  opacity: 0.8;
  transform: scale(0.97);
}

.submit-btn[disabled] {
  opacity: 0.4;
}
