<view class="page-booking">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading}}">
    <!-- 进度 -->
    <view class="progress">
      <view class="pstep {{selectedService ? 'done' : 'on'}}">
        <text class="pdot">{{selectedService ? '✓' : '1'}}</text>
        <text class="plabel">服务</text>
      </view>
      <view class="pline {{selectedService ? 'done' : ''}}"></view>
      <view class="pstep {{selectedDate ? 'done' : (selectedService ? 'on' : '')}}">
        <text class="pdot">{{selectedDate ? '✓' : '2'}}</text>
        <text class="plabel">日期</text>
      </view>
      <view class="pline {{selectedDate ? 'done' : ''}}"></view>
      <view class="pstep {{selectedTime ? 'done' : (selectedDate ? 'on' : '')}}">
        <text class="pdot">{{selectedTime ? '✓' : '3'}}</text>
        <text class="plabel">时间</text>
      </view>
    </view>

    <!-- 选择服务 -->
    <view class="card">
      <view class="card-head"><text class="card-title">选择服务</text></view>
      <view class="svc" wx:if="{{services.length}}">
        <view
          class="svc-row tappable {{selectedService && selectedService._id === item._id ? 'svc-row--on' : ''}}"
          wx:for="{{services}}"
          wx:key="_id"
          bindtap="onSelectService"
          data-index="{{index}}"
        >
          <view class="svc-ic svc-ic--{{item.tone}}">{{item.icon}}</view>
          <view class="svc-main">
            <text class="svc-name">{{item.name}}</text>
            <view class="svc-meta">
              <text class="svc-price">¥{{item.price}}</text>
              <text wx:if="{{item.duration}}"> · {{item.duration}}分钟</text>
            </view>
          </view>
          <view class="svc-radio"></view>
        </view>
      </view>
      <view wx:if="{{!services.length}}" class="empty-pad">
        <view class="empty">
          <view class="empty-icon"></view>
          <text class="empty-text">暂无可用服务</text>
        </view>
      </view>
    </view>

    <!-- 选择日期 -->
    <view class="card" wx:if="{{selectedService}}">
      <view class="card-head"><text class="card-title">选择日期</text></view>
      <view class="cal-nav">
        <view class="cal-arrow l tappable {{calCanPrev ? '' : 'cal-arrow--disabled'}}" bindtap="prevMonth">
          <view class="cal-arrow-icon"></view>
        </view>
        <text class="cal-month">{{calMonthLabel}}</text>
        <view class="cal-arrow r tappable {{calCanNext ? '' : 'cal-arrow--disabled'}}" bindtap="nextMonth">
          <view class="cal-arrow-icon"></view>
        </view>
      </view>

      <view class="cal-wd">
        <text>日</text><text>一</text><text>二</text><text>三</text><text>四</text><text>五</text><text>六</text>
      </view>

      <view class="cal-grid">
        <view
          class="cal-cell {{cell.day === 0 ? 'cal-cell--blank' : ''}} {{!cell.selectable ? 'cal-cell--disabled' : 'tappable'}} {{cell.isSelected ? 'cal-cell--on' : ''}} {{cell.isToday ? 'cal-cell--today' : ''}}"
          wx:for="{{calCells}}"
          wx:for-item="cell"
          wx:key="index"
          bindtap="onSelectDate"
          data-date="{{cell.date}}"
          data-selectable="{{cell.selectable}}"
        >
          <text class="cal-day" wx:if="{{cell.day}}">{{cell.day}}</text>
        </view>
      </view>
    </view>

    <!-- 选择时间 -->
    <view class="card" wx:if="{{selectedDate}}">
      <view class="card-head">
        <text class="card-title">选择时间</text>
        <text class="card-hint" wx:if="{{!loadingSlots && availableCount > 0}}">剩余 {{availableCount}} 个时段</text>
        <text class="card-hint card-hint--full" wx:if="{{!loadingSlots && allBooked}}">该日期已约满</text>
      </view>
      <view class="slot-load" wx:if="{{loadingSlots}}">
        <t-loading theme="circular" size="48rpx" />
      </view>
      <view class="time-grid" wx:if="{{!loadingSlots}}">
        <view
          class="slot tappable {{item.available ? (selectedTime === item.time ? 'slot--on' : '') : 'slot--no'}}"
          wx:for="{{timeSlots}}"
          wx:key="time"
          bindtap="onSelectTime"
          data-time="{{item.time}}"
          data-available="{{item.available}}"
        >
          {{item.time}}
        </view>
      </view>
    </view>

    <!-- 补充信息 -->
    <view class="card" wx:if="{{selectedTime}}">
      <view class="card-head"><text class="card-title">预约信息</text><text class="card-opt">必填</text></view>

      <view class="field">
        <text class="field-label">服务方式</text>
        <view class="mode-grid">
          <view
            class="mode-card tappable {{item.selected ? 'mode-card--on' : ''}}"
            wx:for="{{serviceModeOptions}}"
            wx:key="key"
            bindtap="onSelectServiceMode"
            data-key="{{item.key}}"
          >
            <text class="mode-title">{{item.label}}</text>
            <text class="mode-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>

      <view class="field" wx:if="{{serviceMode === 'home'}}">
        <text class="field-label">上门地址</text>
        <textarea
          class="ta ta--address"
          placeholder="填写详细地址，如小区/楼栋/门牌号"
          value="{{serviceAddress}}"
          bindinput="onServiceAddressInput"
          maxlength="200"
        />
      </view>

      <view class="field">
        <text class="field-label">联系方式</text>
        <view class="input-stack">
          <input
            class="line-input"
            type="number"
            placeholder="手机号"
            placeholder-class="line-ph"
            value="{{contactPhone}}"
            bindinput="onContactPhoneInput"
          />
          <input
            class="line-input"
            placeholder="微信号（手机号和微信号至少填一个）"
            placeholder-class="line-ph"
            value="{{contactWechat}}"
            bindinput="onContactWechatInput"
          />
        </view>
      </view>

      <view class="field">
        <text class="field-label">肤质类型</text>
        <view class="chips">
          <view
            class="chip tappable {{item.selected ? 'chip--on' : ''}}"
            wx:for="{{skinTypeOptions}}"
            wx:key="key"
            bindtap="onSelectSkinType"
            data-key="{{item.key}}"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="field">
        <text class="field-label">特殊需求</text>
        <textarea
          class="ta"
          placeholder="过敏史、皮肤问题等..."
          value="{{specialNeeds}}"
          bindinput="onSpecialNeedsInput"
          maxlength="200"
        />
      </view>

      <view class="field">
        <text class="field-label">场合说明</text>
        <textarea
          class="ta"
          placeholder="婚礼主题、活动类型等..."
          value="{{occasion}}"
          bindinput="onOccasionInput"
          maxlength="200"
        />
      </view>
    </view>
  </block>

  <!-- 提交栏 -->
  <view class="dock" wx:if="{{!loading && selectedTime}}">
    <view class="dock-info">
      <text class="dock-svc">{{selectedService.name}} · <text class="dock-price">¥{{selectedService.price}}</text></text>
      <text class="dock-when">{{selectedDateLabel}} {{selectedTime}} · {{serviceMode === 'home' ? '上门' : '到店'}}</text>
    </view>
    <button class="dock-btn" bindtap="submitBooking" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '确认预约'}}
    </button>
  </view>
</view>
