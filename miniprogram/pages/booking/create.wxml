<view class="page-booking">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading}}">
    <view class="steps">
      <!-- 服务项目 -->
      <view class="step-card step-card--open">
        <view class="step-head">
          <view class="step-badge {{selectedService ? 'step-badge--done' : ''}}">1</view>
          <view class="step-title-wrap">
            <text class="step-title">服务项目</text>
            <text class="step-sub" wx:if="{{selectedService}}">已选 {{selectedService.name}}</text>
            <text class="step-sub" wx:else>选择本次预约的妆造服务</text>
          </view>
          <text class="step-state">{{selectedService ? '已选' : '必选'}}</text>
        </view>

        <view class="service-list" wx:if="{{services.length}}">
          <view
            class="service-row tappable {{selectedService && selectedService._id === item._id ? 'service-row--on' : ''}}"
            wx:for="{{services}}"
            wx:key="_id"
            bindtap="onSelectService"
            data-index="{{index}}"
          >
            <view class="service-icon-wrap {{item.cover_image ? 'service-icon-wrap--cover' : ''}}">
              <image class="service-icon" src="{{item.iconPath}}" mode="{{item.iconMode}}" />
            </view>
            <view class="service-main">
              <view class="service-title-line">
                <text class="service-name">{{item.name}}</text>
                <text class="service-tag" wx:if="{{item.categoryLabel}}">{{item.categoryLabel}}</text>
              </view>
              <text class="service-desc">{{item.displayDescription}}</text>
              <view class="service-meta">
                <text wx:if="{{item.duration}}">{{item.duration}}分钟</text>
                <text wx:if="{{item.duration}}"> · </text>
                <text>¥{{item.price}}</text>
              </view>
            </view>
            <view class="service-check">
              <image wx:if="{{selectedService && selectedService._id === item._id}}" src="../../images/booking-check.png" mode="aspectFit" />
            </view>
          </view>
        </view>

        <view wx:if="{{!services.length}}" class="empty-pad">
          <view class="empty">
            <view class="empty-icon"></view>
            <text class="empty-text">暂无可用服务</text>
          </view>
        </view>
      </view>

      <!-- 预约日期 -->
      <view class="step-card {{selectedService ? 'step-card--open' : 'step-card--locked'}}">
        <view class="step-head">
          <view class="step-badge {{selectedDate ? 'step-badge--done' : ''}}">2</view>
          <view class="step-title-wrap">
            <text class="step-title">预约日期</text>
            <text class="step-sub">{{selectedDate ? selectedDateLabel : '选择可预约日期'}}</text>
          </view>
          <text class="step-state" wx:if="{{!selectedService}}">先选服务</text>
          <text class="step-state" wx:elif="{{!loadingSlots && availableCount > 0}}">该日剩余 {{availableCount}} 个时段</text>
          <text class="step-state step-state--warn" wx:elif="{{!loadingSlots && allBooked}}">该日已约满</text>
        </view>

        <view class="step-body" wx:if="{{selectedService}}">
          <view class="cal-nav">
            <view class="cal-arrow l tappable {{calCanPrev ? '' : 'cal-arrow--disabled'}}" bindtap="prevMonth">
              <text></text>
            </view>
            <text class="cal-month">{{calMonthLabel}}</text>
            <view class="cal-arrow r tappable {{calCanNext ? '' : 'cal-arrow--disabled'}}" bindtap="nextMonth">
              <text></text>
            </view>
          </view>

          <view class="cal-wd">
            <text>日</text><text>一</text><text>二</text><text>三</text><text>四</text><text>五</text><text>六</text>
          </view>

          <view class="cal-grid">
            <view
              class="cal-cell {{cell.day === 0 ? 'cal-cell--blank' : ''}} {{!cell.selectable ? 'cal-cell--disabled' : 'tappable'}} {{cell.isSelected ? 'cal-cell--on' : ''}} {{cell.isToday ? 'cal-cell--today' : ''}}"
              wx:for="{{calCells}}"
              wx:for-item="cell"
              wx:key="index"
              bindtap="onSelectDate"
              data-date="{{cell.date}}"
              data-selectable="{{cell.selectable}}"
            >
              <text class="cal-day" wx:if="{{cell.day}}">{{cell.day}}</text>
            </view>
          </view>
          <view class="cal-legend">
            <view class="legend-dot"></view>
            <text>可预约</text>
            <text class="legend-sep">|</text>
            <text>灰色日期不可预约</text>
          </view>
        </view>
      </view>

      <!-- 预约时段 -->
      <view class="step-card {{selectedDate ? 'step-card--open' : 'step-card--locked'}}">
        <view class="step-head">
          <view class="step-badge {{selectedTime ? 'step-badge--done' : ''}}">3</view>
          <view class="step-title-wrap">
            <text class="step-title">预约时段</text>
            <text class="step-sub">{{selectedTime ? selectedTime : '选择具体到店或上门时间'}}</text>
          </view>
          <text class="step-state" wx:if="{{!selectedDate}}">先选日期</text>
          <text class="step-state" wx:elif="{{!loadingSlots && availableCount > 0}}">剩余 {{availableCount}} 个名额</text>
          <text class="step-state step-state--warn" wx:elif="{{!loadingSlots && allBooked}}">已约满</text>
        </view>

        <view class="step-body" wx:if="{{selectedDate}}">
          <view class="slot-load" wx:if="{{loadingSlots}}">
            <t-loading theme="circular" size="48rpx" />
          </view>
          <view wx:if="{{!loadingSlots && timeSlotGroups.length}}">
            <view class="slot-group" wx:for="{{timeSlotGroups}}" wx:key="key" wx:for-item="group">
              <view class="slot-group-head">
                <image class="slot-group-icon" src="{{group.iconPath}}" mode="aspectFit" />
                <text>{{group.label}}</text>
              </view>
              <view class="time-grid">
                <view
                  class="slot tappable {{item.available ? (selectedTime === item.time ? 'slot--on' : '') : 'slot--no'}}"
                  wx:for="{{group.slots}}"
                  wx:key="time"
                  bindtap="onSelectTime"
                  data-time="{{item.time}}"
                  data-available="{{item.available}}"
                >
                  <text class="slot-time">{{item.time}}</text>
                  <text class="slot-note">{{item.available ? '可预约' : '已约满'}}</text>
                </view>
              </view>
            </view>
          </view>
          <view class="slot-empty" wx:if="{{!loadingSlots && !timeSlotGroups.length}}">
            暂无可预约时段，请换一天
          </view>
        </view>
      </view>

      <!-- 联系信息 -->
      <view class="step-card {{selectedTime ? 'step-card--open' : 'step-card--locked'}}">
        <view class="step-head">
          <view class="step-badge {{(contactPhone || contactWechat) ? 'step-badge--done' : ''}}">4</view>
          <view class="step-title-wrap">
            <text class="step-title">联系信息</text>
            <text class="step-sub">手机号和微信号至少填写一个</text>
          </view>
          <text class="step-state">{{selectedTime ? '必填' : '先选时段'}}</text>
        </view>

        <view class="step-body" wx:if="{{selectedTime}}">
          <view class="field-list">
            <view class="field-row">
              <image class="field-icon" src="../../images/booking-phone.png" mode="aspectFit" />
              <text class="field-label">手机号</text>
              <input
                class="field-input"
                type="number"
                placeholder="填写手机号"
                placeholder-class="line-ph"
                value="{{contactPhone}}"
                bindinput="onContactPhoneInput"
              />
            </view>
            <view class="field-row">
              <image class="field-icon" src="../../images/booking-brand-wechat.png" mode="aspectFit" />
              <text class="field-label">微信号</text>
              <input
                class="field-input"
                placeholder="填写微信号"
                placeholder-class="line-ph"
                value="{{contactWechat}}"
                bindinput="onContactWechatInput"
              />
            </view>
          </view>

          <view class="field">
            <text class="field-title">服务方式</text>
            <view class="mode-grid">
              <view
                class="mode-card tappable {{item.selected ? 'mode-card--on' : ''}}"
                wx:for="{{serviceModeOptions}}"
                wx:key="key"
                bindtap="onSelectServiceMode"
                data-key="{{item.key}}"
              >
                <image class="mode-icon" src="{{item.iconPath}}" mode="aspectFit" />
                <view>
                  <text class="mode-title">{{item.label}}</text>
                  <text class="mode-desc">{{item.desc}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="field field-address" wx:if="{{serviceMode === 'home'}}">
            <text class="field-title">上门地址</text>
            <textarea
              class="ta ta--address"
              placeholder="填写详细地址，如小区/楼栋/门牌号"
              value="{{serviceAddress}}"
              bindinput="onServiceAddressInput"
              maxlength="200"
            />
          </view>

          <view class="field">
            <text class="field-title">肤质类型</text>
            <view class="chips">
              <view
                class="chip tappable {{item.selected ? 'chip--on' : ''}}"
                wx:for="{{skinTypeOptions}}"
                wx:key="key"
                bindtap="onSelectSkinType"
                data-key="{{item.key}}"
              >
                {{item.label}}
              </view>
            </view>
          </view>

          <view class="field">
            <text class="field-title">特殊需求</text>
            <textarea
              class="ta"
              placeholder="过敏史、皮肤问题等..."
              value="{{specialNeeds}}"
              bindinput="onSpecialNeedsInput"
              maxlength="200"
            />
          </view>

          <view class="field">
            <text class="field-title">场合说明</text>
            <textarea
              class="ta"
              placeholder="婚礼主题、活动类型等..."
              value="{{occasion}}"
              bindinput="onOccasionInput"
              maxlength="200"
            />
          </view>
        </view>
      </view>
    </view>

    <!-- 提交栏 -->
    <view class="dock">
      <view class="dock-price-area">
        <view class="dock-price-wrap">
          <text class="dock-yen">¥</text>
          <text class="dock-price">{{selectedService ? selectedService.dockPrice : '--'}}</text>
        </view>
        <view class="dock-detail tappable {{selectedService ? '' : 'dock-detail--disabled'}}" bindtap="showBookingDetail">明细</view>
      </view>

      <view class="dock-divider"></view>

      <view class="dock-copy">
        <text class="dock-when">{{selectedDateLabel || '选择日期'}} {{selectedTime || '选择时间'}}</text>
        <text class="dock-svc">{{selectedService ? selectedService.name : '请选择服务'}} · {{serviceMode === 'home' ? '上门服务' : '到店服务'}}</text>
      </view>

      <button
        class="dock-btn"
        bindtap="submitBooking"
        disabled="{{!selectedService || !selectedDate || !selectedTime || (serviceMode === 'home' && !serviceAddress) || (!contactPhone && !contactWechat) || submitting}}"
      >
        {{submitting ? '提交中...' : '确认预约'}}
      </button>
    </view>

    <!-- 预约明细 -->
    <view class="detail-mask {{detailLeaving ? 'detail-mask--leave' : ''}}" wx:if="{{bookingDetailVisible}}" bindtap="hideBookingDetail">
      <view class="detail-sheet {{detailLeaving ? 'detail-sheet--leave' : ''}}" catchtap="noop">
        <view class="detail-head">
          <view class="detail-head-text">
            <text class="detail-title">预约明细</text>
            <text class="detail-sub">提交前请再次核对信息</text>
          </view>
          <view class="detail-close tappable" bindtap="hideBookingDetail"></view>
        </view>

        <!-- 预约主卡 -->
        <view class="hero hero--{{selectedService.tone}}">
          <view class="hero-top">
            <image class="hero-icon" src="{{selectedService.iconPath}}" mode="{{selectedService.iconMode}}" />
            <text class="hero-name">{{selectedService.name}}</text>
            <text class="hero-cat" wx:if="{{selectedService.categoryLabel}}">{{selectedService.categoryLabel}}</text>
          </view>
          <view class="hero-when">
            <text class="hero-date">{{selectedDateLabel ? selectedDateLabel + (weekdayLabel ? ' ' + weekdayLabel : '') : '未选日期'}}</text>
            <text class="hero-dot" wx:if="{{selectedTime}}"> · </text>
            <text class="hero-time" wx:if="{{selectedTime}}">{{selectedTime}}</text>
          </view>
          <view class="hero-mode">
            <image class="hero-mode-icon" src="{{serviceMode === 'home' ? '../../images/booking-home.png' : '../../images/booking-building-store.png'}}" mode="aspectFit" />
            <text class="hero-mode-text">{{serviceMode === 'home' ? '上门服务' : '到店服务'}}</text>
            <text class="hero-addr" wx:if="{{serviceMode === 'home' && serviceAddress}}"> · {{serviceAddress}}</text>
          </view>
        </view>

        <!-- 联系方式 -->
        <view class="sect">
          <text class="sect-title">联系方式</text>
          <view class="kv-card">
            <view class="kv">
              <image class="kv-icon" src="../../images/booking-phone.png" mode="aspectFit" />
              <text class="kv-key">手机号</text>
              <text class="kv-val">{{contactPhone || '未填写'}}</text>
            </view>
            <view class="kv">
              <image class="kv-icon" src="../../images/booking-brand-wechat.png" mode="aspectFit" />
              <text class="kv-key">微信号</text>
              <text class="kv-val">{{contactWechat || '未填写'}}</text>
            </view>
          </view>
        </view>

        <!-- 补充信息（仅当有内容时显示） -->
        <view class="sect" wx:if="{{hasNotes}}">
          <text class="sect-title">补充信息</text>
          <view class="kv-card">
            <view class="kv" wx:if="{{skinTypeLabel}}">
              <text class="kv-key">肤质</text>
              <text class="kv-val">{{skinTypeLabel}}</text>
            </view>
            <view class="kv" wx:if="{{specialNeeds}}">
              <text class="kv-key">特殊需求</text>
              <text class="kv-val">{{specialNeeds}}</text>
            </view>
            <view class="kv" wx:if="{{occasion}}">
              <text class="kv-key">场合</text>
              <text class="kv-val">{{occasion}}</text>
            </view>
          </view>
        </view>

        <!-- 价格合计 -->
        <view class="total">
          <text class="total-label">合计</text>
          <text class="total-amount"><text class="total-yen">¥</text>{{selectedService.price}}</text>
        </view>
      </view>
    </view>
  </block>
</view>
