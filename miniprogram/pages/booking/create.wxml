<view class="page-booking">
  <view class="loading-container" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" text="加载中..." />
  </view>

  <block wx:if="{{!loading}}">
    <view class="steps">
      <view class="step {{selectedService ? 'step--done' : 'step--on'}}">
        <text class="step-num">1</text>
        <text class="step-label">服务</text>
      </view>
      <view class="step-line {{selectedService ? 'step-line--done' : ''}}"></view>
      <view class="step {{selectedDate ? 'step--done' : (selectedService ? 'step--on' : '')}}">
        <text class="step-num">2</text>
        <text class="step-label">日期</text>
      </view>
      <view class="step-line {{selectedDate ? 'step-line--done' : ''}}"></view>
      <view class="step {{selectedTime ? 'step--done' : (selectedDate ? 'step--on' : '')}}">
        <text class="step-num">3</text>
        <text class="step-label">时间</text>
      </view>
    </view>

    <view class="form-block">
      <text class="form-title">选择服务</text>
      <view class="svc-list" wx:if="{{services.length}}">
        <view
          class="svc-row tappable {{selectedService && selectedService._id === item._id ? 'svc-row--on' : ''}}"
          wx:for="{{services}}"
          wx:key="_id"
          bindtap="onSelectService"
          data-index="{{index}}"
        >
          <view class="svc-info">
            <text class="svc-name">{{item.name}}</text>
            <text class="svc-dur" wx:if="{{item.duration}}">{{item.duration}}分钟</text>
          </view>
          <text class="svc-price">{{item.price}}</text>
          <view class="svc-check" wx:if="{{selectedService && selectedService._id === item._id}}"></view>
        </view>
      </view>
      <view wx:if="{{!services.length}}" class="empty-pad">
        <t-empty icon="shop" description="暂无可用服务" />
      </view>
    </view>

    <view class="form-block" wx:if="{{selectedService}}">
      <text class="form-title">选择日期</text>
      <scroll-view scroll-x enhanced show-scrollbar="{{false}}">
        <view class="date-track">
          <view
            class="date tappable {{selectedDate === item.date ? 'date--on' : ''}}"
            wx:for="{{dateList}}"
            wx:key="date"
            bindtap="onSelectDate"
            data-date="{{item.date}}"
          >
            <text class="date-wk">{{item.weekday}}</text>
            <text class="date-num">{{item.day}}</text>
            <text class="date-mo">{{item.month}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="form-block" wx:if="{{selectedDate}}">
      <text class="form-title">选择时间</text>
      <view class="slot-load" wx:if="{{loadingSlots}}">
        <t-loading theme="circular" size="48rpx" />
      </view>
      <view class="time-grid" wx:if="{{!loadingSlots}}">
        <view
          class="time tappable {{item.available ? (selectedTime === item.time ? 'time--on' : 'time--off') : 'time--no'}}"
          wx:for="{{timeSlots}}"
          wx:key="time"
          bindtap="onSelectTime"
          data-time="{{item.time}}"
          data-available="{{item.available}}"
        >
          {{item.time}}
        </view>
      </view>
    </view>

    <view class="form-block" wx:if="{{selectedTime}}">
      <text class="form-title">肤质类型</text>
      <view class="skin-group">
        <view
          class="skin-btn tappable {{item.selected ? 'skin-btn--on' : ''}}"
          wx:for="{{skinTypeOptions}}"
          wx:key="key"
          bindtap="onSelectSkinType"
          data-key="{{item.key}}"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <view class="form-block" wx:if="{{selectedTime}}">
      <text class="form-title">特殊需求</text>
      <textarea
        class="note"
        placeholder="过敏史、皮肤问题等..."
        value="{{specialNeeds}}"
        bindinput="onSpecialNeedsInput"
        maxlength="200"
      />
    </view>

    <view class="form-block" wx:if="{{selectedTime}}">
      <text class="form-title">场合说明</text>
      <textarea
        class="note"
        placeholder="婚礼主题、活动类型等..."
        value="{{occasion}}"
        bindinput="onOccasionInput"
        maxlength="200"
      />
    </view>

    <view class="submit" wx:if="{{selectedTime}}">
      <view class="submit-summary">
        <text class="submit-service">{{selectedService.name}}</text>
        <text class="submit-dot">·</text>
        <text>{{selectedDate}} {{selectedTime}}</text>
      </view>
      <button class="submit-btn" bindtap="submitBooking" disabled="{{submitting}}">
        {{submitting ? '提交中...' : '确认预约'}}
      </button>
    </view>
  </block>
</view>
