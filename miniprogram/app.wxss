page {
  --accent: #9C7A5A;
  --accent-light: #F7F2EC;
  --accent-soft: rgba(156, 122, 90, 0.06);
  --accent-medium: rgba(156, 122, 90, 0.12);
  --accent-dark: #7A5E42;

  --bg: #F5F2EE;
  --bg-elevated: #FDFCF9;

  --separator: rgba(0, 0, 0, 0.05);
  --separator-opaque: #E8E4DF;

  --text-primary: #1F1B18;
  --text-secondary: rgba(0, 0, 0, 0.42);
  --text-tertiary: rgba(0, 0, 0, 0.22);
  --text-link: var(--accent);

  --fill-primary: rgba(0, 0, 0, 0.04);
  --fill-secondary: rgba(0, 0, 0, 0.025);
  --fill-tertiary: rgba(0, 0, 0, 0.015);

  --gold: #C9A96E;
  --gold-bg: rgba(201, 169, 110, 0.08);
  --rose: #C4727F;
  --rose-bg: rgba(196, 114, 127, 0.08);
  --green: #5A9E6F;
  --green-bg: rgba(90, 158, 111, 0.08);
  --orange: #D4864A;
  --orange-bg: rgba(212, 134, 74, 0.08);
  --red: #C4544A;
  --red-bg: rgba(196, 84, 74, 0.08);
  --blue: #5A7FA0;
  --blue-bg: rgba(90, 127, 160, 0.08);
  --purple: #8B6FA0;
  --purple-bg: rgba(139, 111, 160, 0.08);

  --radius-xs: 4rpx;
  --radius-sm: 8rpx;
  --radius-md: 14rpx;
  --radius-lg: 20rpx;
  --radius-xl: 28rpx;

  --fs-xs: 22rpx;
  --fs-sm: 26rpx;
  --fs-base: 32rpx;
  --fs-lg: 40rpx;
  --fs-xl: 48rpx;

  --page-pad: 32rpx;
  --section-gap: 40rpx;

  background-color: var(--bg);
  font-size: var(--fs-sm);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', 'PingFang SC', sans-serif;
  -webkit-font-smoothing: antialiased;
}

.container {
  padding: var(--page-pad);
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.empty-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 50vh;
}

.btn-primary {
  height: 96rpx;
  line-height: 96rpx;
  background-color: var(--accent);
  color: #FDFBF8;
  border-radius: var(--radius-md);
  font-size: var(--fs-sm);
  font-weight: 500;
  border: none;
  padding: 0;
  transition: opacity 0.15s ease;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.97);
}

.btn-outline {
  height: 96rpx;
  line-height: 96rpx;
  background-color: transparent;
  color: var(--accent);
  border-radius: var(--radius-md);
  font-size: var(--fs-sm);
  font-weight: 500;
  border: 2rpx solid var(--accent);
  padding: 0;
  transition: opacity 0.15s ease;
}

.btn-outline::after {
  border: none;
}

.btn-outline:active {
  opacity: 0.8;
  transform: scale(0.97);
}

.tappable {
  transition: opacity 0.12s ease, transform 0.12s ease;
}

.tappable:active {
  opacity: 0.7;
  transform: scale(0.97);
}
