.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  backdrop-filter: blur(8px);
}

.privacy-dialog {
  width: 580rpx;
  background-color: #fff;
  border-radius: var(--radius-xl);
  padding: 56rpx 44rpx 40rpx;
  box-sizing: border-box;
}

.privacy-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 32rpx;
  letter-spacing: 2rpx;
}

.privacy-content {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-bottom: 44rpx;
  letter-spacing: 1rpx;
}

.privacy-link {
  color: var(--accent);
}

.privacy-buttons {
  display: flex;
  gap: 20rpx;
}

.privacy-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  padding: 0;
  margin: 0;
  letter-spacing: 2rpx;
}

.privacy-btn::after {
  border: none;
}

.privacy-btn-disagree {
  background-color: var(--fill-primary);
  color: var(--text-secondary);
}

.privacy-btn-agree {
  background-color: var(--accent);
  color: #fff;
}
